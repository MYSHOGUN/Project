<style>
  .news-img {
    width: 700px; /* กำหนดความกว้างเป็น 50% ของ container */
    height: auto; /* รักษาอัตราส่วนของรูปภาพ */
  }
</style>
<div class="container-fluid mt-4" style="min-height: 84vh; height: 100%;">
    <div id="newsDetails">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h1>รายละเอียดของ <%= newsDetails.title %></h1>
            <% if (typeof user !== 'undefined' && user.role === 'admin') { %>
                    <button type="button" id="updateNewsBtn" class="btn btn-primary"><i class="fas fa-wrench"></i> แก้ไขข่าว</button>
            <% } %>
        </div>
        <div class="justify-content-center align-items-center">
            <div class="text-center mb-4">
                <img src="/image/<%= newsDetails.img.id %>" alt="Flowchart" class="img-fluid news-img">
            </div>
            <div class="text-center mb-2">
                <h2><%= newsDetails.title %></h2>
            </div>
            <div class="text-center mb-2">
                <p><%= newsDetails.data %></p>
            </div>
        </div>
    </div>
    <div id="newsUpdate" class="d-none">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h1>แก้ไขข่าว</h1>
            <button type="button" id="deleteNewsBtn" class="btn btn-secondary"><i class="fas fa-trash-alt"></i> ลบข่าว</button>
        </div>
        <div class="row justify-content-center align-items-center w-100">
            <div id="drop-area" class="mb-4 ml-2" style="border: none;">
                    <img id="imagePreview" src="/image/<%= newsDetails.img.id %>" alt="Image Preview" style="max-height: 300px; width: auto;">
                <input type="file" id="file-input" style="display:none;">
            </div>
        </div>
        <div id="textAddNews" class="mb-4">
            <div class="d-flex align-items-center mb-3" style="gap: 15px;">
                <input type="text" class="form-control" placeholder="ชื่อไฟล์รูปภาพ" id="picName" value="<%= newsDetails.img.filename %>" disabled> 
                <input type="text" class="form-control" placeholder="หัวข้อข่าว" id="newsTitle" value="<%= newsDetails.title %>" name="newsTitle">
            </div>
            <textarea class="form-control" name="newsData" id="newsData" placeholder="เนื้อหาข่าว" style="width: 100%;min-height: 200px;"><%= newsDetails.data %></textarea>
            <div style="justify-content: space-evenly;">
                <button type="submit" class="btn btn-success mt-3" id="saveUpdateNews">บันทึก</button>
                <button type="button" class="btn btn-danger mt-3" id="returnNews">ยกเลิก</button>
            </div>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let selectedFile = null;

    const newsDetails = document.getElementById('newsDetails');
    const newsUpdate = document.getElementById('newsUpdate');
    const dropArea = document.getElementById('drop-area');
    const imagePreview = document.getElementById('imagePreview');
    const fileInput = document.getElementById('file-input');
    const fileNameInput = document.getElementById('picName');

    const initialImageUrl = imagePreview.src;

    const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];

    dropArea.addEventListener('dragover', (event) => {
        event.preventDefault();
        dropArea.classList.add('hover');
    });

    dropArea.addEventListener('dragleave', () => {
        dropArea.classList.remove('hover');
    });

    dropArea.addEventListener('drop', (event) => {
        event.preventDefault();
        dropArea.classList.remove('hover');
        const files = event.dataTransfer.files;
        handleFiles(files);
    });

    dropArea.addEventListener('click', () => {
        fileInput.click();
    });

    fileInput.addEventListener('change', () => {
        const files = fileInput.files;
        handleFiles(files);
    });

    // -------------------------------------------------------------
    // 2. ฟังก์ชันหลัก: จัดการไฟล์และตรวจสอบประเภท
    // -------------------------------------------------------------
    function handleFiles(files) {
        const file = files[0];
        
        // 🚨 รีเซ็ตสถานะทั้งหมดให้กลับไปที่ค่าเริ่มต้นก่อน (คือแสดงข้อความเริ่มต้น)
        selectedFile = null;
        fileNameInput.value = '<%= newsDetails.img.filename %>';
        imagePreview.src = initialImageUrl;;
        
        if (file) {
            if (allowedTypes.includes(file.type)) {
                // ถ้าเป็นรูปภาพที่ยอมรับ
                selectedFile = file; 
                fileNameInput.value = file.name; 

                // **ส่วนการพรีวิวรูปภาพ:**
                const reader = new FileReader(); 
                reader.onload = function(e) {
                    imagePreview.src = e.target.result;         
                    
                };
                reader.readAsDataURL(file); // อ่านไฟล์เป็น Data URL
                
            } else {
                // ถ้าไม่ใช่รูปภาพ: แจ้งเตือนและกลับไปแสดงข้อความเริ่มต้น
                Swal.fire({
                    icon: 'warning',
                    title: 'ไฟล์ไม่ถูกต้อง',
                    html: `ไฟล์ที่เลือกไม่ใช่รูปภาพที่ถูกต้อง (ยอมรับ: JPEG, PNG, GIF, WEBP)<br>ประเภทที่เลือกคือ: <strong>${file.type || 'ไม่ทราบประเภท'}</strong>`,
                    confirmButtonText: 'ตกลง'
                });
                fileInput.value = ''; 
                fileNameInput.value = '<%= newsDetails.img.filename %>'; 
                imagePreview.src = initialImageUrl; // คืนค่า src กลับเป็นรูปเดิม
                selectedFile = null; 
                
                // สถานะจะถูกรีเซ็ตด้านบนอยู่แล้ว
            }
        }
    }

    // เมื่อคลิกปุ่ม "แก้ไขข่าว"
    $('#updateNewsBtn').on('click', function() {
        newsDetails.classList.add('d-none');
        newsUpdate.classList.remove('d-none');
    });

    $('#returnNews').on('click', function() {
        // 1. สลับหน้า
        newsUpdate.classList.add('d-none');
        newsDetails.classList.remove('d-none');

        // 2. รีเซ็ตค่าฟอร์มกลับสู่ค่าเดิม
        selectedFile = null;
        fileInput.value = '';
        imagePreview.src = initialImageUrl; 
        fileNameInput.value = '<%= newsDetails.img.filename %>';
        $('#newsTitle').val('<%= newsDetails.title %>');
        $('#newsData').val('<%= newsDetails.data %>');
    });

    $("#saveUpdateNews").on("click", function() {
        const title = $('#newsTitle').val();
        const content = $('#newsData').val();
        // 1. สร้าง FormData เพื่อรองรับการส่งไฟล์
        const formData = new FormData();
        formData.append('newsTitle', title);
        formData.append('newsData', content);
        
        // 2. ถ้ามีการเลือกไฟล์ใหม่ ให้แนบไฟล์ไปด้วย
        if (selectedFile) {
            formData.append('newImage', selectedFile); // ชื่อ field ต้องตรงกับที่ Server รับ
        }

        $.ajax({
            url: "/news-update/<%= newsDetails._id %>",
            method: "POST", // หรือ PUT ตามที่คุณกำหนดใน Server
            // 🚨 ลบ contentType: "application/json" เมื่อใช้ FormData
            data: formData,
            processData: false, // 🚨 ต้องตั้งค่าเป็น false เมื่อใช้ FormData
            contentType: false, // 🚨 ต้องตั้งค่าเป็น false เมื่อใช้ FormData
            success: function(res) {
                Swal.fire({
                    icon: 'success',
                    title: 'อัปเดตข่าวสำเร็จ',
                    text: 'ข่าวได้รับการอัปเดตเรียบร้อยแล้ว',
                    confirmButtonText: 'ตกลง'
                });
                window.location.reload(); 
            },
            error: function(err) {
                Swal.fire({
                    icon: 'error',
                    title: 'อัปเดตข่าวไม่สำเร็จ',
                    text: 'เกิดข้อผิดพลาดในการอัปเดตข่าว',
                    confirmButtonText: 'ตกลง'
                });
            }
        });
    });

    $('#deleteNewsBtn').on('click', function() {
        const newsId = '<%= newsDetails._id %>';
        
        if (confirm("คุณแน่ใจหรือไม่ว่าต้องการลบข่าว: <%= newsDetails.title %>")) {
            $.ajax({
                // ใช้ method เป็น DELETE และส่ง request ไปยัง endpoint สำหรับลบ
                url: "/news-delete/" + newsId, 
                method: "DELETE",
                success: function(res) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ลบข่าวสำเร็จ',
                        text: 'ข่าวได้รับการลบเรียบร้อยแล้ว',
                        confirmButtonText: 'ตกลง'
                    }).then(() => {
                        window.location.href = '/'; // สมมติว่าหน้ารายการข่าวคือ /news-list
                    });
                },
                error: function(err) {
                    Swal.fire({
                        icon: 'error',
                        title: 'ลบข่าวไม่สำเร็จ',
                        text: 'เกิดข้อผิดพลาดในการลบข่าว',
                        confirmButtonText: 'ตกลง'
                    });
                }
            });
        }
    });
</script>