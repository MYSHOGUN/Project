<style>
    /* จัดการ Container หลักให้กึ่งกลางหน้าจอพอดี */
    .add-user-wrapper {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        min-height: 80vh !important;
        width: 100% !important;
    }

    /* กล่อง Card หลักขยายให้ใหญ่และสมดุล */
    .user-card {
        width: 100% !important;
        max-width: 1100px !important; /* ปรับให้กว้างขึ้นเพื่อความพรีเมียม */
        background: #ffffff !important;
        border-radius: 20px !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
        padding: 3.5rem !important;
    }

    /* หัวข้อหน้า */
    .page-title {
        color: #4e73df !important;
        font-weight: 700 !important;
        text-align: center !important;
        margin-bottom: 2.5rem !important;
    }

    /* จัดระเบียบช่องกรอกข้อมูลให้กระจายเท่ากัน (50/50) */
    .input-group-row {
        display: flex !important;
        gap: 1.5rem !important;
        margin-bottom: 2.5rem !important;
        width: 100% !important;
        align-items: flex-end !important;
    }

    .input-field-container {
        flex: 1 !important; /* บังคับให้ขยายกว้างเท่ากันทั้งสองฝั่ง */
    }

    /* ปรับแต่งสไตล์ Input ให้ใหญ่และดูดี */
    .custom-input {
        width: 100% !important;
        height: 60px !important;
        padding: 0 1.5rem !important;
        font-size: 1.1rem !important;
        border: 2px solid #e3e6f0 !important;
        border-radius: 12px !important;
        transition: all 0.3s !important;
    }

    .custom-input:focus {
        border-color: #4e73df !important;
        box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.1) !important;
        outline: none !important;
    }

    /* ปรับแต่ง Select ให้เหมือนกับ Input */
    .custom-select {
        width: 100% !important;
        height: 60px !important;
        font-size: 1.1rem !important;
        border: 2px solid #e3e6f0 !important;
        border-radius: 12px !important;
        color: #6e707e !important;
        cursor: pointer !important;
    }

    .label-text {
        font-weight: 700 !important;
        color: #4e73df !important;
        margin-bottom: 8px !important;
        display: block !important;
        text-transform: uppercase !important;
        letter-spacing: 0.5px !important;
        font-size: 0.9rem !important;
    }
</style>

<div class="container-fluid">
    <div class="add-user-wrapper">
        <div class="user-card">
            
            <div class="page-title">
                <h1 class="font-weight-bold"><i class="fas fa-user-edit mr-3"></i>เพิ่มข้อมูลผู้ใช้รายคน</h1>
                <p class="text-muted mt-2">กรุณาระบุรหัสประจำตัว เลือกตำแหน่งและเลือกสาขาของผู้ใช้</p>
            </div>

            <div class="input-group-row">
                <div class="input-field-container">
                    <label class="label-text">รหัสประจำตัว</label>
                    <input type="text" class="custom-input" id="username" name="username" placeholder="ระบุรหัสนักศึกษา/อาจารย์">
                </div>

                <div class="input-field-container">
                    <label class="label-text">ตำแหน่งผู้ใช้</label>
                    <select class="custom-select px-3" id="role">
                        <option selected disabled>เลือกตำแหน่ง...</option>
                        <option value="student">นักศึกษา</option>
                        <option value="teacher">อาจารย์</option>
                    </select>
                </div>

                <div class="input-field-container">
                    <label class="label-text">สาขาผู้ใช้</label>
                    <select class="custom-select px-3" id="branch">
                        <option selected disabled>เลือกสาขา...</option>
                        <option value="enet">EnET</option>
                        <option value="ect">ECT</option>
                    </select>
                </div>
            </div>

            <div class="d-flex justify-content-center mt-5">
                <button type="submit" class="btn btn-success btn-lg px-5 mr-3 shadow" id="saveUser" style="border-radius: 12px; font-weight: 700;">
                    <i class="fas fa-save mr-2"></i>บันทึกข้อมูล
                </button>
                <button type="button" class="btn btn-danger btn-lg px-5 shadow" id="cancelBtn" onclick="history.back()" style="border-radius: 12px; font-weight: 700;">
                    <i class="fas fa-times mr-2"></i>ยกเลิก
                </button>
            </div>

        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.getElementById('saveUser').addEventListener('click', async function(e) {
    e.preventDefault();

    const username = document.getElementById('username').value.trim();
    const role = document.getElementById('role').value;
    const branch = document.getElementById('branch').value;

    // 1. ตรวจสอบข้อมูลเบื้องต้น
    if (!username || !role || role === "เลือกตำแหน่ง..." || !branch || branch === "เลือกสาขา...") {
        Swal.fire({
            icon: 'warning',
            title: 'ข้อมูลไม่ครบ',
            text: 'กรุณาระบุรหัสประจำตัว เลือกตำแหน่ง และเลือกสาขาให้ถูกต้อง',
            confirmButtonColor: '#4e73df'
        });
        return;
    }

    // 2. แสดงหน้าต่างยืนยัน (Confirm)
    const result = await Swal.fire({
        title: 'ยืนยันการเพิ่มผู้ใช้?',
        text: `รหัส: ${username} (${role === 'student' ? 'นักศึกษา' : 'อาจารย์'}) สาขา: ${branch.toUpperCase()}`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#1cc88a',
        cancelButtonColor: '#e74a3b',
        confirmButtonText: 'ใช่, บันทึกเลย',
        cancelButtonText: 'ยกเลิก',
        reverseButtons: true
    });

    if (result.isConfirmed) {
        // แสดง Loading
        Swal.fire({
            title: 'กำลังบันทึก...',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        try {
            const response = await fetch("/api/addUserSingle", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ username, role, branch })
            });

            const data = await response.json();

            if (data.success) {
                await Swal.fire({
                    icon: 'success',
                    title: 'สำเร็จ!',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                });
                window.location.href = "/addUser"; 
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'เกิดข้อผิดพลาด',
                    text: data.error
                });
            }
        } catch (err) {
            console.error(err);
            Swal.fire({
                icon: 'error',
                title: 'เซิร์ฟเวอร์ขัดข้อง',
                text: 'ไม่สามารถเชื่อมต่อกับฐานข้อมูลได้ในขณะนี้'
            });
        }
    }
});
</script>