<style>
    /* จัดการ Container หลักให้กึ่งกลางหน้าจอพอดี */
    .add-user-wrapper {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        min-height: 85vh !important; /* เพิ่มพื้นที่แนวตั้งเล็กน้อย */
        padding: 2rem 0 !important;
        width: 100% !important;
    }

    /* กล่อง Card หลักขยายให้ใหญ่และสมดุล */
    .user-card {
        width: 95% !important; /* ให้มีช่องว่างขอบจอเล็กน้อย */
        max-width: 1100px !important;
        background: #ffffff !important;
        border-radius: 20px !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
        padding: 3.5rem !important;
    }

    /* ✅ แก้ไขจุดนี้: ปรับ Row ให้ขึ้นบรรทัดใหม่ได้เมื่อพื้นที่ไม่พอ */
    .input-group-row {
        display: flex !important;
        flex-wrap: wrap !important; /* อนุญาตให้ขึ้นบรรทัดใหม่ */
        gap: 1.5rem !important; /* ระยะห่างระหว่างฟิลด์ */
        margin-bottom: 2rem !important;
        width: 100% !important;
        justify-content: center !important; /* จัดกลุ่มให้อยู่กลางบรรทัด */
    }

    /* ✅ ปรับความกว้างขั้นต่ำเพื่อให้สมดุลตอนขึ้นบรรทัดใหม่ */
    .input-field-container {
        flex: 1 1 300px !important; /* กว้างขั้นต่ำ 300px ถ้าไม่พอจะดีดลงมาเอง */
        max-width: 100% !important;
        display: flex !important;
        flex-direction: column !important;
    }

    /* ปรับแต่งสไตล์ Input และ Select */
    .custom-input, .custom-select {
        width: 100% !important;
        height: 55px !important; /* ลดความสูงเล็กน้อยให้ดูพอดี */
        padding: 0 1.2rem !important;
        font-size: 1.05rem !important;
        border: 2px solid #eaecf4 !important;
        border-radius: 12px !important;
        transition: all 0.3s !important;
    }

    .custom-input:focus, .custom-select:focus {
        border-color: #4e73df !important;
        box-shadow: 0 0 0 0.25rem rgba(78, 115, 223, 0.1) !important;
        outline: none !important;
    }

    .label-text {
        font-weight: 700 !important;
        color: #4e73df !important;
        margin-bottom: 10px !important;
        font-size: 0.9rem !important;
        text-transform: uppercase !important;
    }

    /* จัดการปุ่มให้สมดุลบนมือถือ */
    @media (max-width: 576px) {
        .user-card { padding: 2rem !important; }
        .btn-lg { width: 100% !important; margin-bottom: 10px !important; margin-right: 0 !important; }
        .d-flex.justify-content-center { flex-direction: column !important; }
    }
</style>

<div class="container-fluid">
    <div class="add-user-wrapper">
        <div class="user-card">
            
            <div class="page-title text-center mb-5">
                <h1 class="font-weight-bold text-primary"><i class="fas fa-user-plus mr-3"></i>เพิ่มข้อมูลผู้ใช้</h1>
                <p class="text-muted">ระบุรายละเอียดคำนำหน้า ชื่อ นามสกุล รหัสประจำตัวและตำแหน่ง</p>
            </div>

            <div class="input-group-row">
                <div class="input-field-container">
                    <label class="label-text">คำนำหน้า</label>
                    <select class="custom-select" id="title">
                        <option selected disabled>เลือกคำนำหน้า...</option>
                        <option value="MR">นาย</option>
                        <option value="MS">นางสาว</option>
                        <option value="MRS">นาง</option>
                    </select>
                </div>

                <div class="input-field-container">
                    <label class="label-text">ชื่อ</label>
                    <input type="text" class="custom-input" id="name" placeholder="ชื่อ">
                </div>

                <div class="input-field-container">
                    <label class="label-text">นามสกุล</label>
                    <input type="text" class="custom-input" id="lastname" placeholder="นามสกุล">
                </div>

                <div class="input-field-container">
                    <label class="label-text">รหัสประจำตัว</label>
                    <input type="text" class="custom-input" id="username" placeholder="รหัสนักศึกษา/อาจารย์">
                </div>

                <div class="input-field-container">
                    <label class="label-text">ตำแหน่งผู้ใช้</label>
                    <select class="custom-select" id="role">
                        <option selected disabled>เลือกตำแหน่ง...</option>
                        <option value="student">นักศึกษา</option>
                        <option value="teacher">อาจารย์</option>
                    </select>
                </div>

            </div>

            <div class="d-flex justify-content-center mt-4">
                <button type="button" class="btn btn-success btn-lg px-5 mr-0 mr-sm-3 shadow" id="saveUser" style="border-radius: 12px; font-weight: 700;">
                    <i class="fas fa-save mr-2"></i>บันทึกข้อมูล
                </button>
                <button type="button" class="btn btn-danger btn-lg px-5 shadow border" onclick="history.back()" style="border-radius: 12px; font-weight: 700;">
                    ยกเลิก
                </button>
            </div>

        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.getElementById('saveUser').addEventListener('click', async function(e) {
    e.preventDefault();

    const username = document.getElementById('username').value.trim();
    const role = document.getElementById('role').value;
    const title = document.getElementById('title').value;
    const name = document.getElementById('name').value.trim();
    const lastname = document.getElementById('lastname').value.trim();
    const titleText = title === 'MR' ? 'นาย' : title === 'MS' ? 'นางสาว' : title === 'MRS' ? 'นาง' : null
    // 1. ตรวจสอบข้อมูลเบื้องต้น
    if (!username || !role || role === "เลือกตำแหน่ง..." || !title || title === "เลือกคำนำหน้า..." || !name || !lastname) {
        Swal.fire({
            icon: 'warning',
            title: 'ข้อมูลไม่ครบ',
            text: 'กรุณาระบุรหัสประจำตัว เลือกตำแหน่ง และเลือกสาขาให้ถูกต้อง',
            confirmButtonColor: '#4e73df'
        });
        return;
    }

    // 2. แสดงหน้าต่างยืนยัน (Confirm)
    const result = await Swal.fire({
        title: 'ยืนยันการเพิ่มผู้ใช้?',
        text: `${titleText} ${name} ${lastname} รหัส: ${username} (${role === 'student' ? 'นักศึกษา' : 'อาจารย์'}) สาขา: ${branch.toUpperCase()}`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#1cc88a',
        cancelButtonColor: '#e74a3b',
        confirmButtonText: 'ใช่, บันทึกเลย',
        cancelButtonText: 'ยกเลิก',
        reverseButtons: true
    });

    if (result.isConfirmed) {
        // แสดง Loading
        Swal.fire({
            title: 'กำลังบันทึก...',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        try {
            const response = await fetch("/api/addUserSingle", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ titleText , name , lastname , username, role })
            });

            const data = await response.json();

            if (data.success) {
                await Swal.fire({
                    icon: 'success',
                    title: 'สำเร็จ!',
                    text: data.message,
                    timer: 2000,
                    showConfirmButton: false
                });
                window.location.href = "/addUser"; 
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'เกิดข้อผิดพลาด',
                    text: data.error
                });
            }
        } catch (err) {
            console.error(err);
            Swal.fire({
                icon: 'error',
                title: 'เซิร์ฟเวอร์ขัดข้อง',
                text: 'ไม่สามารถเชื่อมต่อกับฐานข้อมูลได้ในขณะนี้'
            });
        }
    }
});
</script>