<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title><%= title %></title>

    <!-- Custom fonts for this template-->
    <link href="vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link
        href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
        rel="stylesheet">

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/img/LOGO-KMUTNB--300x300.png">
    
    <!-- Custom styles for this template-->
    <link href="css/myProject.css" rel="stylesheet">

    <style>
        .form-group{
            width: 100%;
        }
    </style>

</head>

<body class="bg-gradient-primary">

    <div class="container">

        <!-- Outer Row -->
        <div class="row justify-content-center align-items-center">

            <div class="col-xl-10 col-lg-12 col-md-9" style="width: 90%;">

                <div class="card o-hidden border-0 shadow-lg my-5">
                    <div class="card-header">
                        <div class="row-12">
                            <i class="fas fa-tasks"></i>
                            <span>&nbsp;กรอกข้อมูลสมัครเข้าใช้งาน</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="p-5 justify-content-center align-items-center">
                            <form class="user" action="/register" method="POST">
                                <div class="d-flex justify-content-center align-items-center"  style="gap: 15px; width: 100%;">
                                    <div class="form-group">
                                        <small id="usernameText">รหัสนักศึกษา</small>
                                        <input type="username" name="username" class="form-control"
                                            id="inputUsername" aria-describedby="usernameText"
                                            placeholder="Username">
                                    </div>
                                </div>
                                <div class="d-flex justify-content-center align-items-center"  style="gap: 15px; width: 100%;">
                                    <div class="form-group">
                                        <small id="passwordText">รหัสผ่าน</small>
                                        <input type="password" name="password" class="form-control"
                                            id="inputPassword" aria-describedby="passwordText"
                                            placeholder="Password">
                                    </div>
                                    <div class="form-group">
                                        <small id="passwordConfirm">ยืนยันรหัสผ่าน</small>
                                        <input type="password" name="passwordConfirm" class="form-control"
                                            id="inputPasswordConfirm" aria-describedby="passwordConfirm"
                                            placeholder="Password Confirm">
                                    </div>
                                </div>
                                <div class="d-flex justify-content-center align-items-center"  style="gap: 15px; width: 100%;">
                                    <div class="form-group">
                                        <small id="nameText">ชื่อ</small>
                                        <input type="text" name="name" class="form-control"
                                            id="inputName" aria-describedby="nameText"
                                            placeholder="Name">
                                    </div>
                                    <div class="form-group">
                                        <small id="lastnameText">นามสกุล</small>
                                        <input type="text" name="lastname" class="form-control"
                                            id="inputLastname" aria-describedby="lastnameText"
                                            placeholder="Lastname">
                                    </div>
                                </div>
                                <div class="d-flex justify-content-center align-items-center"  style="gap: 15px; width: 100%;">
                                    <div class="form-group">
                                        <small id="emailText">อีเมล</small>
                                        <input type="email" name="email" class="form-control"
                                            id="inputEmail" aria-describedby="emailText"
                                            placeholder="Email">
                                    </div>
                                    <div class="form-group">
                                        <small id="phoneText">เบอร์โทรศัพท์</small>
                                        <input type="text" name="phone" class="form-control"
                                            id="inputPhone" aria-describedby="phoneText"
                                            placeholder="Phone Number">
                                    </div>
                                </div>
                                <div class="d-flex justify-content-center align-items-center mt-3"  style="gap: 15px; width: 100%;">
                                    <button type="submit" class="btn btn-success">
                                        ลงทะเบียน
                                    </button>
                                    <button type="reset" class="btn btn-danger">
                                        ยกเลิก
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

    <div class="modal fade" id="loginFailModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
            aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content border-left-danger">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel">ลงทะเบียนไม่สำเร็จ</h5>
                        <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">×</span>
                        </button>
                    </div>
                    <% if (failModal === "exists") { %>
                        <div class="modal-body">ไม่มีชื่อผู้ใช้นี้ในระบบ</div>
                    <% } else if (failModal === "complete") { %>
                        <div class="modal-body">ผู้ใช้ถูกลงทะเบียนแล้ว</div>
                    <% } else if (failModal === "mismatch") { %>
                        <div class="modal-body">รหัสผ่านไม่ตรงกัน</div>
                    <% }%>
                </div>
            </div>
        </div>


    <!-- Bootstrap core JavaScript-->
    <script src="vendor/jquery/jquery.min.js"></script>
    <script src="vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Core plugin JavaScript-->
    <script src="vendor/jquery-easing/jquery.easing.min.js"></script>

    <!-- Custom scripts for all pages-->
    <script src="js/sb-admin-2.min.js"></script>

    <script>
        const failModal = "<%= failModal %>";
        if (failModal) {
            console.log(failModal);
            $(document).ready(function() {
            $('#loginFailModal').modal('show');
            });
        }
    </script>

</body>

</html>