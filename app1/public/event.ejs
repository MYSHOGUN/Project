<style>
    /* จัดการ Layout หลักให้กึ่งกลางและดูสะอาดตา */
    .event-wrapper {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        min-height: 85vh !important;
        padding-top: 2rem !important;
    }

    .event-container-box {
        width: 100% !important;
        max-width: 1000px !important; /* คุมความกว้างให้ดูสมดุล */
    }

    /* ตกแต่ง Card ให้ดูพรีเมียม */
    .event-card-item {
        border-radius: 15px !important;
        border: none !important;
        transition: all 0.3s ease !important;
        cursor: pointer !important;
        background: #fff !important;
    }

    .event-card-item:hover {
        transform: translateY(-5px) !important;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    /* ตกแต่ง Icon ให้ดูเด่นขึ้น */
    .event-icon-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8f9fc;
        color: #4e73df;
    }
</style>

<div class="container-fluid">
    <div class="event-wrapper">
        
        <div class="d-flex align-items-center justify-content-between mb-5 event-container-box">
            <h1 class="font-weight-bold text-gray-800" style="font-size: 2.2rem;">
                <i class="fas fa-calendar-alt mr-3 text-primary"></i>ตารางกิจกรรม
            </h1>
            <% if (user && user.role === 'admin') { %>
                <button class="btn btn-primary btn-icon-split shadow-sm" onclick="location.href='/addEvent'" style="border-radius: 10px;">
                    <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
                    <span class="text">เพิ่มกิจกรรม</span>
                </button>
            <% } %>
        </div>

        <div class="event-container-box">
            <div id="eventListContainer">
                <div class="text-center mt-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">กำลังโหลดข้อมูลกิจกรรม...</p>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    async function loadEvents() {
        try {
            const response = await fetch('/api/getEvents');
            const events = await response.json();
            const container = document.getElementById('eventListContainer');

            if (events.length === 0) {
                container.innerHTML = `
                    <div class="card shadow-sm border-0 text-center py-5" style="border-radius: 15px;">
                        <div class="card-body">
                            <i class="fas fa-calendar-times fa-4x text-gray-200 mb-3"></i>
                            <h4 class="text-gray-500">ยังไม่มีกิจกรรมที่ประกาศไว้</h4>
                        </div>
                    </div>`;
                return;
            }

            container.innerHTML = ''; 

            events.forEach(ev => {
                const startDate = new Date(ev.date).toLocaleDateString('th-TH', {
                    day: '2-digit', month: 'long', year: 'numeric'
                });

                let dateRange = startDate;
                if (ev.toDate && ev.toDate !== ev.date) {
                    const endDate = new Date(ev.toDate).toLocaleDateString('th-TH', {
                        day: '2-digit', month: 'long', year: 'numeric'
                    });
                    dateRange = `${startDate} - ${endDate}`;
                }

                // เลือกสีและไอคอนตามประเภทกิจกรรม
                let colorClass = "primary";
                let iconClass = "fa-clipboard-list";
                if (ev.title === "วันสอบ") { colorClass = "danger"; iconClass = "fa-exclamation-circle"; }
                if (ev.title === "วันส่งเอกสาร") { colorClass = "warning"; iconClass = "fa-file-upload"; }

                const eventHtml = `
                    <a href="/eventInfo/${ev.id}" class="text-decoration-none mb-4 d-block">
                        <div class="card event-card-item shadow-sm border-left-${colorClass}">
                            <div class="card-body p-4">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-3">
                                        <div class="text-xs font-weight-bold text-${colorClass} text-uppercase mb-1" style="letter-spacing: 1px;">
                                            ${ev.title}
                                        </div>
                                        <div class="h4 mb-2 font-weight-bold text-gray-800">${dateRange}</div>
                                        <div class="text-gray-600">${ev.description || 'ดูรายละเอียดเพิ่มเติมคลิกที่นี่'}</div>
                                    </div>
                                    <div class="col-auto">
                                        <div class="event-icon-circle text-${colorClass}">
                                            <i class="fas ${iconClass} fa-lg"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                `;
                container.insertAdjacentHTML('beforeend', eventHtml);
            });
        } catch (err) {
            console.error("Error:", err);
            container.innerHTML = '<div class="text-center text-danger p-5">โหลดข้อมูลล้มเหลว กรุณาลองใหม่อีกครั้ง</div>';
        }
    }

    document.addEventListener("DOMContentLoaded", loadEvents);
</script>