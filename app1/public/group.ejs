<div class="container-fluid" style="padding: 0; margin: 0; height: 85vh; line-height: normal;">
    <!-- Page Heading -->
        <div class="row flex-column flex-sm-row" style="height: 100%;">

    <!-- รายชื่อ -->
    <div id="group-list-section" class="col-sm-4 col-12" style="background-color: lightgrey; height: 100%; width: 33.3333%;">
      <div class="mx-4 mt-4">
        <h2>รายชื่อกลุ่ม</h2>
        <ul class="list-group" id="group-list">

          <% groups.forEach(g => { %>
            <li class="list-group-item group-item mb-2" data-groupname="<%= g.projectName %>" data-groupid="<%= g._id %>">
              <div class="d-flex flex-column">
                <strong><%= g.projectName %></strong>
                <span>Status: <%= g.status %></span>
              </div>
            </li>
          <% }) %>
          
        </ul>
        <div class="d-flex flex-row" style="margin-bottom: 20px; justify-content: space-evenly;">
          <button id="addMemberBtn" class="btn btn-light" style="width: 45%;">เพิ่มสมาชิก</button>
          <button id="leaveGroupBtn" class="btn btn-danger" style="width: 45%;">ออกจากกลุ่ม</button>
        </div>
      </div>
    </div>                     

    <!-- ระบบแชท -->
    <div id="chat-section" class="col-sm-8 col-12 d-flex flex-column " style="height: 100%; display: none; width: 66.6666%;">
      <div class="mt-4 mx-4 d-flex align-items-center justify-content-between">
        <h2>
          แชทกลุ่ม: <span id="chat-with">-</span>
        </h2>
        <button id="back-button" class="btn btn-secondary d-sm-none">
          <i class="bi bi-arrow-bar-left"></i> ย้อนกลับ
        </button>
      </div>

      <div style="flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column;" id="messages-container">
        <!-- ข้อความแชท -->
      </div>
      <div id="file-preview-box" class="mx-4" style="display: flex; gap: 5px; flex-wrap: wrap;"></div>
      <form id="chat-form" class="d-flex align-items-center mx-4 my-2" style="gap: 10px;">
        <div class="input-group">
          <input id="message-input" autocomplete="off" placeholder="พิมพ์ข้อความ..." class="form-control" style="border-top-left-radius: 10rem; border-bottom-left-radius: 10rem;">
          <label 
            id="file-input"
            for="file-upload" 
            class="form-control" 
            style="cursor: pointer; display: flex; justify-content: center; align-items: center; padding: 0; margin-bottom: 0; border-top-right-radius: 10rem; border-bottom-right-radius: 10rem;">
            <i class="fas fa-plus"></i>
          </label>
          <input id="file-upload" type="file" hidden multiple>
        </div>
        <button id="message-sent" class="form-control form-control-chat btn btn-primary" style="display: flex; justify-content: center; align-items: center; padding: 0;">
          ส่ง
        </button>
      </form>
    </div>
  </div>
  <script>
document.addEventListener("DOMContentLoaded", () => {
  const socket = io({ query: { username: "<%= user.username %>" } });
  const groupListSection = document.getElementById("group-list-section");
  const groupList = document.getElementById('group-list');
  const chatSection = document.getElementById('chat-section');
  const chatWithEl = document.getElementById('chat-with');
  const messagesContainer = document.getElementById('messages-container');
  const messageInput = document.getElementById('message-input');
  const chatForm = document.getElementById('chat-form');
  const backButton = document.getElementById('back-button');

  const fileInput = document.getElementById('file-upload');
  const filePreviewBox = document.getElementById('file-preview-box');

  let currentGroupId = "<%= groups.length > 0 ? groups[0]._id : '' %>";
  let currentGroupName = "<%= groups.length > 0 ? groups[0].projectName : '' %>";

  let selectedFiles = [];

  const addMemberBtn = document.getElementById('addMemberBtn');
  const leaveGroupBtn = document.getElementById('leaveGroupBtn');

  fileInput.addEventListener('change', () => {
    const files = Array.from(fileInput.files);
    selectedFiles = files; // เก็บไฟล์ทั้งหมด
    filePreviewBox.innerHTML = ''; // เคลียร์ preview เดิม

    selectedFiles.forEach((file, index) => {
      // สร้าง pill
      const pill = document.createElement('div');
      pill.className = 'd-flex align-items-center px-2 py-1 bg-secondary text-white rounded-pill';
      pill.style.fontSize = '0.9rem';
      pill.style.gap = '5px';
      
      const text = document.createElement('span');
      text.textContent = file.name;
      pill.appendChild(text);

      // ปุ่ม x ยกเลิก
      const removeBtn = document.createElement('span');
      removeBtn.textContent = '✕';
      removeBtn.style.cursor = 'pointer';
      removeBtn.onclick = () => {
        selectedFiles.splice(index, 1); // ลบไฟล์ออกจาก array
        updatePreview(); // อัปเดต preview ใหม่
      };
      pill.appendChild(removeBtn);

      filePreviewBox.appendChild(pill);
    });
  });

  function updatePreview() {
    filePreviewBox.innerHTML = '';
    selectedFiles.forEach((file, index) => {
      const pill = document.createElement('div');
      pill.className = 'd-flex align-items-center px-2 py-1 bg-secondary text-white rounded-pill';
      pill.style.fontSize = '0.9rem';
      pill.style.gap = '5px';

      const text = document.createElement('span');
      text.textContent = file.name;
      pill.appendChild(text);

      const removeBtn = document.createElement('span');
      removeBtn.textContent = '✕';
      removeBtn.style.cursor = 'pointer';
      removeBtn.onclick = () => {
        selectedFiles.splice(index, 1);
        updatePreview();
      };
      pill.appendChild(removeBtn);

      filePreviewBox.appendChild(pill);
    });
  }

  function joinGroup(groupId, groupName) {
    currentGroupId = groupId;
    chatWithEl.textContent = groupName;
    messagesContainer.innerHTML = '';
    messageInput.disabled = false;

    // join room
    socket.emit("join group", groupId);

    // โหลดข้อความเก่า
    fetch(`/group/messages/group/${groupId}`)
      .then(res => res.json())
      .then(data => {
        console.log("📥 messages from server:", data);

        if (Array.isArray(data.messages)) {
          data.messages.forEach(msg => {
            console.log("👉 rendering msg:", msg); // ✅ log ตรงนี้
            addMessage(msg);
          });
          
          messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
      });

    showChatSection();
  }

  // เลือกกลุ่มเพื่อแชท
  groupList.addEventListener("click", e => {
    const li = e.target.closest('.group-item');
    if (!li) return;
    const groupId = li.dataset.groupid;
    const groupName = li.dataset.groupname;
    if (currentGroupId === groupId && window.innerWidth > 576) return;
    joinGroup(groupId, groupName);
  });

  function addMessage(msg){
    console.log("🖊️ addMessage called with:", msg); // ✅
    const div = document.createElement('div');
    if(msg.type === "file" && msg.file && msg.file.fileId){
      div.innerHTML = `${msg.senderName}: <a href="/file/download/${msg.file.fileId}" download="${msg.file.filename}"> ${msg.file.filename}</a>`;
    } else {
      div.textContent = `${msg.senderName}: ${msg.text}`;
    }
    
  const currentUser = "<%= user.username %>".trim();
  const sender = (msg.senderUsername || "").trim();

  if(sender.trim() === currentUser.trim()){
    div.classList.add('chat-messages-sent');
  } else {
    div.classList.add('chat-messages-received');
  }

    messagesContainer.appendChild(div);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  // ส่งข้อความ
  chatForm.addEventListener("submit", e => {
    e.preventDefault();
    if(!currentGroupId) return alert("กรุณาเลือกกลุ่มก่อน");

    const text = messageInput.value.trim();
    if(!text && selectedFiles.length === 0) return;

    const formData = new FormData();
    formData.append("text", text);
    selectedFiles.forEach(file => formData.append("files", file));

    fetch(`/upload-file/${currentGroupId}`, {
      method: "POST",
      body: formData
    })
    .then(res => {
      if (!res.ok) return res.text().then(t => Promise.reject(new Error(t)));
      return res.json();
    })
    .then(messages => {
      // messages เป็น array ของไฟล์ที่อัปโหลด
      
      messageInput.value = '';
      selectedFiles = [];
      fileInput.value = '';
      filePreviewBox.innerHTML = '';
    })
    .catch(err => alert("เกิดข้อผิดพลาด: " + err.message));
  });

  // รับข้อความใหม่
  socket.on("group message", msg => {
    if(msg.groupId === currentGroupId){
      addMessage(msg);
    }
  });

  // ปุ่มย้อนกลับ
  backButton.addEventListener('click', () => {
    showGroupListSection();
  });
  // ปุ่มออกจากกลุ่ม
  leaveGroupBtn.addEventListener('click', () => {
    if(confirm("คุณแน่ใจหรือไม่ว่าต้องการออกจากกลุ่มนี้?")){
      fetch(`/groups/leave/${currentGroupId}`, { method: 'POST' })
        .then(res => {
          if(res.ok){
            alert("คุณได้ออกจากกลุ่มเรียบร้อยแล้ว");
            window.location.reload();
          } else {
            res.text().then(text => alert("เกิดข้อผิดพลาด: " + text));
          }
        })
        .catch(err => alert("เกิดข้อผิดพลาด: " + err.message));
    }
  });
  // ปุ่มเพิ่มสมาชิก
  addMemberBtn.addEventListener('click', () => {
      window.location.href = '/updateGroup';
  });

  // Layout responsive
  function showChatSection(){
    if (window.innerWidth < 576) { // จอเล็ก ซ่อนรายชื่อ
        groupListSection.style.display = "none";
        chatSection.style.display = "flex";
        groupListSection.style.width = "100%";
        chatSection.style.width = "100%";
      } else if(window.innerWidth >= 576 && window.innerWidth < 960){ // จอกลาง รายชื่อแสดงพร้อมแชทแต่ปรับขนาด
        groupListSection.style.display = "block";
        chatSection.style.display = "flex";
        groupListSection.style.width = "50%";
        chatSection.style.width = "50%";
      } else { // จอใหญ่ รายชื่อแสดงพร้อมแชท
        groupListSection.style.display = "block";
        chatSection.style.display = "flex";
        groupListSection.style.width = "33.3333%";
        chatSection.style.width = "66.6666%";
      }
  }

  function showGroupListSection(){
    if (window.innerWidth < 576) { // จอเล็ก แสดงรายชื่ออย่างเดียว
        groupListSection.style.display = "block";
        groupListSection.style.width = "100%";
        chatSection.style.display = "none";
        chatSection.style.width = "100%";
      } else if(window.innerWidth >= 576 && window.innerWidth < 960){ // จอกลาง รายชื่อแสดงพร้อมแชทแต่ปรับขนาด
        groupListSection.style.display = "block";
        chatSection.style.display = "flex";
        groupListSection.style.width = "50%";
        chatSection.style.width = "50%";
      } else { // จอใหญ่ แสดงทั้งสองฝั่ง
        groupListSection.style.display = "block";
        groupListSection.style.width = "33.3333%";
        chatSection.style.display = "flex";
        chatSection.style.width = "66.6666%";
      }
  }

  if (currentGroupId) {
    // ถ้ามีกลุ่ม → join และแสดงแชทเลย
    joinGroup(currentGroupId, currentGroupName);
    showChatSection();
  } else {
    // ถ้าไม่มีกลุ่ม → แสดงรายชื่อกลุ่มหรือปุ่มสร้างกลุ่ม
    showGroupListSection();
    messageInput.disabled = true;
  }

  window.addEventListener('resize', () => {
    if(!currentGroupId){
      showGroupListSection();
    } else {
      showChatSection();
    }
  });
});
</script>
</div>
