<style>
    /* จัดการ Container หลักให้กึ่งกลางหน้าจอ */
    .admin-grant-wrapper {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        min-height: 80vh !important;
        width: 100% !important;
    }

    /* กล่อง Card หลักขยายให้ใหญ่และสมดุล */
    .admin-card {
        width: 100% !important;
        max-width: 850px !important;
        background: #ffffff !important;
        border-radius: 20px !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
        padding: 3.5rem !important;
        text-align: center !important;
    }

    /* ปรับแต่งช่องค้นหา */
    #secretaryContainer {
        position: relative;
        width: 100% !important;
        margin-bottom: 1.5rem !important;
    }

    #secretaryUsername,#secretaryEmail {
        height: 60px !important;
        font-size: 1.25rem !important;
        border-radius: 12px !important;
        border: 2px solid #e3e6f0 !important;
    }
</style>

<div class="container-fluid">
    <div class="admin-grant-wrapper">
        <div class="admin-card">
            
            <div class="mb-5">
                <h1 class="font-weight-bold" style="color: #4e73df;">
                    <i class="fas fa-user-shield mr-3"></i>เพิ่มตำแหน่งเลขานุการ
                </h1>
                <p class="text-muted">เพิ่มข้อมูลของเลขานุการ</p>
            </div>

            <div id="secretaryContainer">
                <input type="text" id="secretaryUsername" class="form-control mb-3" placeholder="ชื่อผู้ใช้ของเลขานุการ">
                <input type="email" id="secretaryEmail" class="form-control" placeholder="อีเมลของเลขานุการ">
            </div>

            <div class="mt-4">
                <button type="button" id="updateSecretaryRole" class="btn btn-success btn-lg px-5 shadow" disabled style="border-radius: 12px; font-weight: 700;">
                    <i class="fas fa-save mr-2"></i>บันทึกการลงทะเบียนเลขานุการ
                </button>
            </div>

        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // ✅ ตรวจสอบ input 2 ช่อง ถ้ามีค่าครบให้เปิดปุ่ม
    function checkInputs() {
        const username = $("#secretaryUsername").val().trim();
        const email = $("#secretaryEmail").val().trim();
        if (username && email) {
            $("#updateSecretaryRole").prop("disabled", false);
        } else {
            $("#updateSecretaryRole").prop("disabled", true);
        }
    }

    $("#secretaryUsername, #secretaryEmail").on("input", checkInputs);

    // ✅ ปรับปรุงส่วนบันทึกด้วย SweetAlert2
    $("#updateSecretaryRole").on("click", async function() {       
        const secretaryUsername = $("#secretaryUsername").val();
        const secretaryEmail = $("#secretaryEmail").val();


        // 1. ถามเพื่อยืนยัน
        const result = await Swal.fire({
            title: 'ยืนยันการเพิ่มเลขานุการ?',
            text: `คุณกำลังจะเพิ่มตำแหน่งเลขานุการโดยใช้ชื่อผู้ใช้: ${secretaryUsername}`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#1cc88a',
            cancelButtonColor: '#e74a3b',
            confirmButtonText: 'ยืนยันการเพิ่มผู้ใช้',
            cancelButtonText: 'ยกเลิก',
            reverseButtons: true
        });

        // 2. ถ้ากดยืนยัน
        if (result.isConfirmed) {
            // แสดงสถานะ Loading
            Swal.fire({
                title: 'กำลังบันทึกข้อมูล...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            $.ajax({
                url: "/api/addSecretary", // Backend API ของคุณ
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify({ username: secretaryUsername, email: secretaryEmail }),
                success: function(res) {
                    Swal.fire({
                        icon: 'success',
                        title: 'อัปเดตสำเร็จ!',
                        text: 'เพิ่มตำแหน่งเลขานุการเรียบร้อยแล้ว',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.reload(); 
                    });
                },
                error: function(err) {
                    Swal.fire({
                        icon: 'error',
                        title: 'เกิดข้อผิดพลาด',
                        text: err.responseText || "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้"
                    });
                }
            });
        }
    });
</script>