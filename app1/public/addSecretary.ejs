<style>
    /* จัดการ Container หลักให้กึ่งกลางหน้าจอ */
    .admin-grant-wrapper {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        min-height: 80vh !important;
        width: 100% !important;
    }

    /* กล่อง Card หลักขยายให้ใหญ่และสมดุล */
    .admin-card {
        width: 100% !important;
        max-width: 850px !important;
        background: #ffffff !important;
        border-radius: 20px !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
        padding: 3.5rem !important;
        text-align: center !important;
    }

    /* ปรับแต่งช่องค้นหา */
    #searchAdvisorContainer {
        position: relative;
        width: 100% !important;
        margin-bottom: 1.5rem !important;
    }

    #searchAdvisor {
        height: 60px !important;
        font-size: 1.25rem !important;
        border-radius: 12px !important;
        border: 2px solid #e3e6f0 !important;
    }

    /* ผลลัพธ์การค้นหา */
    #searchAdvisorResults {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1050;
        max-height: 250px;
        overflow-y: auto;
        background: white;
        box-shadow: 0 8px 16px rgba(0,0,0,0.1) !important;
        border-radius: 0 0 12px 12px !important;
    }

    /* ส่วนแสดงผลเมื่อเลือกอาจารย์แล้ว */
    #selectedAdvisorContainer {
        background: #f8f9fc !important;
        border: 2px solid #4e73df !important;
        border-radius: 15px !important;
        padding: 1.5rem !important;
        margin-bottom: 2rem !important;
        width: 100% !important;
    }
</style>

<div class="container-fluid">
    <div class="admin-grant-wrapper">
        <div class="admin-card">
            
            <div class="mb-5">
                <h1 class="font-weight-bold" style="color: #4e73df;">
                    <i class="fas fa-user-shield mr-3"></i>มอบสิทธิ์เลขานุการ
                </h1>
                <p class="text-muted">ค้นหารายชื่ออาจารย์เพื่อทำการมอบสิทธิ์เลขานุการ</p>
            </div>

            <div id="searchAdvisorContainer">
                <input type="text" id="searchAdvisor" class="form-control" placeholder="ค้นหาชื่ออาจารย์ที่ปรึกษา...">
                <ul id="searchAdvisorResults" class="list-group text-left"></ul>
            </div>

            <div id="selectedAdvisorContainer" style="display:none;">
                <div class="d-flex align-items-center justify-content-between">
                    <h3 id="selectedAdvisor" class="font-weight-bold text-dark mb-0"></h3>
                    <button id="clearAdvisorSelection" class="btn btn-danger btn-circle shadow-sm">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>

            <div class="mt-4">
                <button type="button" id="updateSecretaryRole" class="btn btn-success btn-lg px-5 shadow" disabled style="border-radius: 12px; font-weight: 700;">
                    <i class="fas fa-save mr-2"></i>บันทึกการมอบสิทธิ์
                </button>
            </div>

        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    let chosenAdvisor = null;
    
    // Logic การค้นหาเดิมของคุณ
    $("#searchAdvisor").on("keyup", function() {
        const keyword = $(this).val().trim();
        const $results = $("#searchAdvisorResults");
        $results.empty();
        
        if (keyword.length > 0) {
            $.get("/search-advisor?keyword=" + encodeURIComponent(keyword), function(data) {
                $results.empty();
                if (data && data.length > 0) {
                    data.forEach(function(user) {
                        const $li = $(`<li class="list-group-item list-group-item-action p-3" style="cursor:pointer;">
                            <i class="fas fa-user-tie mr-2 text-primary"></i> ${user.name} ${user.lastname} (${user.username})
                        </li>`);
                        $li.on("click", function() {
                            chosenAdvisor = user.username;
                            $("#selectedAdvisor").text(`อาจารย์: ${user.name} ${user.lastname}`);
                            $("#searchAdvisorContainer").hide();
                            $("#selectedAdvisorContainer").fadeIn();
                            updateButtonState();
                            $results.empty();
                        });
                        $results.append($li);
                    });
                } else {
                    $results.append(`<li class="list-group-item text-muted p-3">ไม่พบข้อมูลผู้ใช้</li>`);
                }
            });
        }
    });

    $("#clearAdvisorSelection").on("click", function() {
        chosenAdvisor = null;
        $("#selectedAdvisorContainer").hide();
        $("#searchAdvisorContainer").fadeIn();
        $("#searchAdvisor").val('').focus();
        updateButtonState();
    });

    function updateButtonState() {
        $("#updateSecretaryRole").prop("disabled", !chosenAdvisor);
    }

    // ✅ ปรับปรุงส่วนบันทึกด้วย SweetAlert2
    $("#updateSecretaryRole").on("click", async function() {
        if (!chosenAdvisor) return;
        
        const advisorName = $("#selectedAdvisor").text();

        // 1. ถามเพื่อยืนยัน
        const result = await Swal.fire({
            title: 'ยืนยันการมอบสิทธิ์?',
            text: `คุณกำลังจะมอบสิทธิ์ "เลขานุการ" ให้แก่ ${advisorName}`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#1cc88a',
            cancelButtonColor: '#e74a3b',
            confirmButtonText: 'ยืนยันมอบสิทธิ์',
            cancelButtonText: 'ยกเลิก',
            reverseButtons: true
        });

        // 2. ถ้ากดยืนยัน
        if (result.isConfirmed) {
            // แสดงสถานะ Loading
            Swal.fire({
                title: 'กำลังบันทึกข้อมูล...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            $.ajax({
                url: "/api/addSecretary", // Backend API ของคุณ
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify({ username: chosenAdvisor }),
                success: function(res) {
                    Swal.fire({
                        icon: 'success',
                        title: 'อัปเดตสำเร็จ!',
                        text: 'มอบสิทธิ์อาจารย์หัวหน้าแขนงเรียบร้อยแล้ว',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.reload(); 
                    });
                },
                error: function(err) {
                    Swal.fire({
                        icon: 'error',
                        title: 'เกิดข้อผิดพลาด',
                        text: err.responseText || "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้"
                    });
                }
            });
        }
    });
</script>