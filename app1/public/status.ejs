<style>
    .content-group {
        min-width: 400px;
        width: 45%;
    }
    @media (max-width: 480px) {
        .content-group {
            min-width: 100% !important;
            width: 100%;
        }
    }
</style>
<div class="container-fluid mt-4" style="min-height: 84vh;">                
    <div class="mb-4">
        <h1 style="font-weight: bold; color: #4e73df;">สถานะปริญญานิพนธ์</h1>
    </div>

    <div class="row g-4" id="row" style="justify-content: space-evenly;">
        <% groups.forEach(g => { %>
            <div class="col-12 col-md-6 mb-3 content-group">
                <a href="#" class="text-decoration-none text-dark">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 15px;">
                        <div class="card-body p-4">
                            <div class="card-title d-flex justify-content-between align-items-center">
                                <h4 class="mb-0" style="font-weight: bold; color: #333;"><%= g.projectName %></h4>
                                <span style="color: #28a745; font-size: 0.9rem; font-weight: 500;">
                                    หัวหน้า: <%= g.leaderName %>
                                </span>
                            </div>
                            <hr class="my-3" style="opacity: 0.1;">
                            <div class="d-flex align-items-center">
                                <p class="mb-0 text-muted mr-1" style="font-size: 0.9rem;">สถานะปริญญานิพนธ์:</p>
                                <span class="badge rounded-pill px-3 py-2" style="background-color: #f8f9fc; color: #4e73df; border: 1px solid #e3e6f0;">
                                    <%= g.status %>
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        <% }) %>
    </div>
</div>