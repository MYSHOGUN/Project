<div class="container-fluid mt-4" style="min-height: 84vh;">                
    <div class="mb-4">
        <h1 style="color: #4e73df;">สถานะปริญญานิพนธ์</h1>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 40vw), 1fr)); gap: 1.5rem; width: 100%;">
        <input type="text" class="form-control mb-4" placeholder="ค้นหาปริญญานิพนธ์..." style="max-width: 400px;">
        <% groups.forEach(g => { %>
            <div class="content-group">
                <a href="#" class="text-decoration-none text-dark d-block h-100">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; transition: transform 0.2s; border-left: 5px solid #4e73df;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h4 class="mb-0 font-weight-bold" style="color: #333; font-size: 1.2rem;">
                                    <%= g.projectName %>
                                </h4>
                                <span class="text-success small font-weight-bold ml-2" style="white-space: nowrap;">
                                    หัวหน้า: <%= g.leaderName ? g.leaderName : " -" %>
                                </span>
                            </div>
                            <hr class="my-3" style="opacity: 0.1;">
                            <div class="d-flex align-items-center">
                                <span class="text-muted small mr-2">สถานะ:</span>
                                <span class="badge rounded-pill px-3 py-2" style="background-color: #f8f9fc; color: #4e73df; border: 1px solid #e3e6f0;">
                                    <%= g.status %>
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        <% }) %>
    </div>
</div>

<style>
    /* ใส่ Hover effect ให้ดูพรีเมียม */
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>