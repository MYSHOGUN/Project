<style>
    /* 1. Layout & Containers */
    .update-group-card {
        background: white; padding: 2.5rem; border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        max-width: 650px; width: 95%; margin: 40px auto;
    }

    #searchContainer, #searchAdvisorContainer { position: relative; width: 100%; }

    #searchMemberResults, #searchAdvisorResults {
        position: absolute; top: 100%; left: 0; right: 0; z-index: 1050;
        max-height: 200px; overflow-y: auto; background: white;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        border: 1px solid #e3e6f0; border-radius: 10px; margin-top: 5px; display: none;
    }

    /* 2. Visual Elements */
    .project-title-box {
        background: #f8f9fc; border-left: 5px solid #4e73df;
        padding: 15px 20px; border-radius: 8px; margin-bottom: 25px;
    }

    .member-item {
        display: flex; align-items: center; padding: 12px 18px;
        background: #fff; border: 1px solid #e3e6f0;
        border-radius: 12px; margin-bottom: 12px; transition: 0.3s;
    }

    .btn-add-member {
        border: 2px dashed #d1d3e2; background: transparent; color: #858796;
        border-radius: 12px; padding: 15px; width: 100%; transition: 0.3s;
    }
    .btn-add-member:hover { border-color: #4e73df; color: #4e73df; background: #f0f3ff; }

    .badge-role { font-size: 0.75rem; padding: 4px 10px; border-radius: 20px; margin-left: auto; }
</style>

<div class="container-fluid d-flex align-items-start justify-content-center" style="min-height: 100vh; background: #f4f7f6; padding-top: 20px;">
    <div id="server-data" data-groups='<%- JSON.stringify(groups || []) %>' hidden></div>

    <div id="grouping" class="update-group-card d-flex flex-column">
        <div class="text-center mb-4">
            <h2 class="font-weight-bold text-primary">จัดการสมาชิกกลุ่ม</h2>
            <p class="text-muted">ตรวจสอบและเพิ่มรายชื่อสมาชิกในโปรเจกต์ของคุณ</p>
        </div>

        <div class="project-title-box">
            <small class="text-primary font-weight-bold uppercase">ชื่อปริญญานิพนธ์</small>
            <h4 class="mb-0 mt-1 font-weight-bold text-gray-800"><%= groups[0].projectName %></h4>
        </div>

        <div class="project-title-box">
            <small class="text-primary font-weight-bold uppercase">ชื่อปริญญานิพนธ์ (ภาษาอังกฤษ)</small>
            <h4 class="mb-0 mt-1 font-weight-bold text-gray-800"><%= groups[0].engName %></h4>
        </div>

        <div class="mb-4">
            <label class="font-weight-bold text-gray-700 mb-3"><i class="fas fa-users mr-2"></i> สมาชิกนักศึกษา</label>
            
            <div class="member-item border-left-primary">
                <i class="fas fa-user-circle fa-2x text-gray-300 mr-3"></i>
                <div>
                    <h6 class="mb-0 font-weight-bold"><%= userInfo[0].name %> <%= userInfo[0].lastname %></h6>
                    <small class="text-muted"><%= userInfo[0].username %></small>
                </div>
                <span class="badge-role bg-primary text-white ml-auto">หัวหน้ากลุ่ม</span>
            </div>

            <% if (userInfo[1]) { %>
                <div class="member-item border-left-success">
                    <i class="fas fa-user-circle fa-2x text-gray-300 mr-3"></i>
                    <div>
                        <h6 class="mb-0 font-weight-bold"><%= userInfo[1].name %> <%= userInfo[1].lastname %></h6>
                        <small class="text-muted"><%= userInfo[1].username %></small>
                    </div>
                    <span class="badge-role bg-success text-white ml-auto">สมาชิก</span>
                </div>
            <% } else { %>
                <button type="button" id="addMemberBtn" class="btn-add-member mt-2">
                    <i class="fas fa-user-plus mr-2"></i> เพิ่มสมาชิกคนที่ 2
                </button>

                <div id="searchContainer" class="d-none mt-2">
                    <div class="input-group shadow-sm">
                        <input type="text" id="searchUser" class="form-control" placeholder="ค้นหาชื่อหรือรหัสนักศึกษา...">
                        <div class="input-group-append">
                            <button id="clearAddMemberBtn" class="btn btn-outline-danger">ยกเลิก</button>
                        </div>
                    </div>
                    <ul id="searchMemberResults" class="list-group"></ul>
                </div>

                <div class="member-item border-left-info mt-2" id="selectedContainer" style="display:none; background: #f0faff;">
                    <i class="fas fa-check-circle text-info mr-3"></i>
                    <strong id="selectedUser" class="text-info"></strong>
                    <button id="clearSelection" class="btn btn-sm btn-link text-danger ml-auto">แก้ไข</button>
                </div>
            <% } %>
        </div>

        <div class="mb-4">
            <label class="font-weight-bold text-gray-700 mb-3"><i class="fas fa-chalkboard-teacher mr-2"></i> อาจารย์ที่ปรึกษา</label>
            
            <% if (userInfo[2]) { %>
                <div class="member-item" style="border-left: 5px solid #f6c23e; background: #fffdf5;">
                    <i class="fas fa-user-tie fa-2x text-warning mr-3"></i>
                    <div>
                        <h6 class="mb-0 font-weight-bold">อ. <%= userInfo[2].name %> <%= userInfo[2].lastname %></h6>
                        <small class="text-muted">Advisor</small>
                    </div>
                </div>
            <% } else { %>
                <button type="button" id="addAdvisorBtn" class="btn-add-member">
                    <i class="fas fa-plus mr-2"></i> เพิ่มอาจารย์ที่ปรึกษา
                </button>

                <div id="searchAdvisorContainer" class="d-none mt-2">
                    <div class="input-group shadow-sm">
                        <input type="text" id="searchAdvisor" class="form-control" placeholder="ค้นหาชื่ออาจารย์...">
                        <div class="input-group-append">
                            <button id="clearAddAdvisorBtn" class="btn btn-outline-danger">ยกเลิก</button>
                        </div>
                    </div>
                    <ul id="searchAdvisorResults" class="list-group"></ul>
                </div>

                <div class="member-item mt-2" id="selectedAdvisorContainer" style="display:none; border-left: 5px solid #f6c23e; background: #fffdf5;">
                    <i class="fas fa-check-circle text-warning mr-3"></i>
                    <strong id="selectedAdvisor" class="text-warning"></strong>
                    <button id="clearAdvisorSelection" class="btn btn-sm btn-link text-danger ml-auto">แก้ไข</button>
                </div>
            <% } %>
        </div>

        <div class="mt-4 d-flex" style="gap: 15px;">
            <button type="submit" id="updateGroupBtn" class="btn btn-success flex-grow-1 py-3 font-weight-bold shadow-sm" style="border-radius: 12px;" disabled>
                <i class="fas fa-save mr-2"></i> บันทึกการเปลี่ยนแปลง
            </button>
            <button class="btn btn-light border px-4 py-3" onclick="window.location.href='/group'" style="border-radius: 12px; color: #e74a3b;">
                ยกเลิก
            </button>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(function() {
        let chosenUser = null;
        let chosenAdvisor = null;
        const serverData = document.getElementById('server-data');
        const groups = JSON.parse(serverData.dataset.groups || '[]');

        function updateButtonState() {
            if (chosenUser !== null || chosenAdvisor !== null) {
                $("#updateGroupBtn").prop("disabled", false).addClass("shadow");
            } else {
                $("#updateGroupBtn").prop("disabled", true).removeClass("shadow");
            }
        }

        // --- Search Student ---
        $("#addMemberBtn").on("click", function() {
            $(this).hide();
            $("#searchContainer").removeClass("d-none").fadeIn();
        });

        $("#clearAddMemberBtn").on("click", function() {
            $("#searchContainer").addClass("d-none");
            $("#addMemberBtn").fadeIn();
            $("#searchUser").val('');
            $("#searchMemberResults").empty();
        });

        $("#searchUser").on("keyup", function() {
            const keyword = $(this).val().trim();
            const $results = $("#searchMemberResults");
            if (keyword.length > 1) {
                $.get("/search-users?keyword=" + encodeURIComponent(keyword), function(data) {
                    $results.empty().show();
                    if (data && data.length > 0) {
                        data.forEach(user => {
                            $results.append(`<li class="list-group-item list-group-item-action search-li" data-username="${user.username}" data-fullname="${user.name} ${user.lastname}">
                                <strong>${user.name} ${user.lastname}</strong> <small class="text-muted">(${user.username})</small>
                            </li>`);
                        });
                    } else {
                        $results.append(`<li class="list-group-item text-muted">ไม่พบข้อมูล</li>`);
                    }
                });
            } else { $results.hide(); }
        });

        $(document).on("click", ".search-li", function() {
            const username = $(this).data("username");
            const fullname = $(this).data("fullname");
            chosenUser = username;
            $("#selectedUser").text(fullname);
            $("#searchContainer").hide();
            $("#selectedContainer").fadeIn().css("display", "flex");
            updateButtonState();
        });

        $("#clearSelection").on("click", function() {
            chosenUser = null;
            $("#selectedContainer").hide();
            $("#searchContainer").show();
            updateButtonState();
        });

        // --- Search Advisor (Logic เดียวกับด้านบน) ---
        $("#addAdvisorBtn").on("click", function() {
            $(this).hide();
            $("#searchAdvisorContainer").removeClass("d-none").fadeIn();
        });

        $("#searchAdvisor").on("keyup", function() {
            const keyword = $(this).val().trim();
            const $results = $("#searchAdvisorResults");
            if (keyword.length > 1) {
                $.get("/search-advisor?keyword=" + encodeURIComponent(keyword), function(data) {
                    $results.empty().show();
                    data.forEach(user => {
                        $results.append(`<li class="list-group-item list-group-item-action adv-li" data-username="${user.username}" data-fullname="${user.name} ${user.lastname}">
                            <strong>อ. ${user.name} ${user.lastname}</strong>
                        </li>`);
                    });
                });
            }
        });

        $(document).on("click", ".adv-li", function() {
            chosenAdvisor = $(this).data("username");
            $("#selectedAdvisor").text("อ. " + $(this).data("fullname"));
            $("#searchAdvisorContainer").hide();
            $("#selectedAdvisorContainer").fadeIn().css("display", "flex");
            updateButtonState();
        });

        $("#clearAdvisorSelection").on("click", function() {
            chosenAdvisor = null;
            $("#selectedAdvisorContainer").hide();
            $("#searchAdvisorContainer").show();
            updateButtonState();
        });

        $("#updateGroupBtn").on("click", function() {
            const groupData = {
                member2: chosenUser || groups[0].member2,
                advisor: chosenAdvisor || groups[0].advisor
            };

            $.ajax({
                url: "/groups-update/<%= groups.length > 0 ? groups[0]._id : '' %>",
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify(groupData),
                success: function() {
                    alert("อัปเดตข้อมูลกลุ่มสำเร็จ!");
                    window.location.href = "/group";
                },
                error: function(err) { alert("เกิดข้อผิดพลาด: " + err.responseText); }
            });
        });
    });
</script>