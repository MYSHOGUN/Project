<script src="/socket.io/socket.io.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // 1. ไปหาตัวเก็บค่าที่เราฝากไว้ใน HTML
        const bridge = document.getElementById('socket-bridge');
        
        // ถ้าไม่มีตัวเก็บค่า (แปลว่าไม่ได้ Login) ก็ไม่ต้องรันโค้ดข้างล่าง
        if (!bridge) return;

        // 2. ดึง username ออกมา
        const currentUsername = bridge.getAttribute('data-username');
        
        // 3. เริ่มรันระบบ Socket
        const socket = io({ query: { username: currentUsername } });
        const notiBadge = document.getElementById('noti-badge');
        const notiContainer = document.getElementById('noti-container');

        function getNotiItemHTML(data) {
            const content = data.messageText || data.text;
            const sender = data.senderName;
            const link = `/chat?groupId=${data.groupId}`;

            return `
                <a class="dropdown-item d-flex align-items-center" href="${link}">
                    <div class="dropdown-list-image mr-3">
                        <img class="rounded-circle" src="/img/undraw_profile.svg" alt="...">
                        <div class="status-indicator bg-success"></div>
                    </div>
                    <div class="font-weight-bold">
                        <div class="text-truncate">${content}</div>
                        <div class="small text-gray-500">${sender} · เมื่อสักครู่</div>
                    </div>
                </a>`;
        }

        // --- โหลดข้อมูลเก่าจาก DB ---
        fetch('/api/notifications/unread')
            .then(res => res.json())
            .then(notifications => {
                if (notifications && notifications.length > 0) {
                    notiBadge.textContent = notifications.length;
                    notiBadge.style.display = 'block';
                    notifications.forEach(noti => {
                        notiContainer.insertAdjacentHTML('beforeend', getNotiItemHTML(noti));
                    });
                }
            })
            .catch(err => console.log("ยังไม่มีข้อมูลแจ้งเตือนใหม่"));

        // --- รับข้อมูลสดๆ ---
        socket.on("new_notification", function(data) {
            let currentCount = parseInt(notiBadge.textContent) || 0;
            notiBadge.textContent = currentCount + 1;
            notiBadge.style.display = 'block';
            notiContainer.insertAdjacentHTML('afterbegin', getNotiItemHTML(data));
        });
    });
</script>
<!-- End of Topbar -->