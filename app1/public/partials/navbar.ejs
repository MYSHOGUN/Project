<!-- Topbar -->
 <% if (typeof user !== "undefined" && user) { %>
    <div id="socket-bridge" data-username="<%= user.username %>" style="display: none;"></div>
<% } %>
<nav class="navbar navbar-expand navbar-light bg-white topbar static-top shadow">

    <!-- Sidebar Toggle (Topbar) -->
    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
        <i class="fa fa-bars"></i>
    </button>

    <!-- Topbar Search -->
    <!-- <form
        class="d-none d-sm-inline-block form-inline mr-auto ml-md-3 my-2 my-md-0 mw-100 navbar-search">
        <div class="input-group">
            <input type="text" class="form-control bg-light border-0 small" placeholder="Search for..."
                aria-label="Search" aria-describedby="basic-addon2">
            <div class="input-group-append">
                <button class="btn btn-primary" type="button">
                    <i class="fas fa-search fa-sm"></i>
                </button>
            </div>
        </div>
    </form> -->

    <!-- Topbar Navbar -->
    <ul class="navbar-nav ml-auto">

        <!-- Nav Item - Search Dropdown (Visible Only XS) -->
        <li class="nav-item dropdown no-arrow d-sm-none">
            <a class="nav-link dropdown-toggle" href="#" id="searchDropdown" role="button"
                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="fas fa-search fa-fw"></i>
            </a>
            <!-- Dropdown - Messages -->
            <div class="dropdown-menu dropdown-menu-right p-3 shadow animated--grow-in"
                aria-labelledby="searchDropdown">
                <form class="form-inline mr-auto w-100 navbar-search">
                    <div class="input-group">
                        <input type="text" class="form-control bg-light border-0 small"
                            placeholder="Search for..." aria-label="Search"
                            aria-describedby="basic-addon2">
                        <div class="input-group-append">
                            <button class="btn btn-primary" type="button">
                                <i class="fas fa-search fa-sm"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </li>

        <!-- Nav Item - Alerts -->
        <li class="nav-item dropdown no-arrow mx-1">
            <a class="nav-link dropdown-toggle" href="#" id="alertsDropdown" role="button"
                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="fas fa-bell fa-fw"></i>
                <span id="alert-badge" class="badge badge-danger badge-counter" style="display: none;">0</span>
            </a>
            <div class="dropdown-list dropdown-menu dropdown-menu-right shadow animated--grow-in" aria-labelledby="alertsDropdown">
                <h6 class="dropdown-header">Alerts Center</h6>
                <div id="alert-container"></div>
                
                <a id="load-more-alerts-btn" class="dropdown-item text-center small text-gray-500" href="javascript:void(0)">
                    Read More Alerts
                </a>
            </div>
        </li>

        <!-- Nav Item - Messages -->
        <li class="nav-item dropdown no-arrow mx-1">
            <a class="nav-link dropdown-toggle" href="#" id="messagesDropdown" role="button"
                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="fas fa-envelope fa-fw"></i>
                <span id="noti-badge" class="badge badge-danger badge-counter" style="display: none;">0</span>
            </a>
            <div class="dropdown-list dropdown-menu dropdown-menu-right shadow animated--grow-in"
                aria-labelledby="messagesDropdown">
                <h6 class="dropdown-header">
                    Message Center
                </h6>
                
                <div id="noti-container">
                    </div>

                <a id="load-more-btn" class="dropdown-item text-center small text-gray-500" href="javascript:void(0)">
                    Read More Messages
                </a>
            </div>
        </li>

        <div class="topbar-divider d-none d-sm-block"></div>

        <!-- Nav Item - User Information -->
        <li class="nav-item dropdown no-arrow">
            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <% if (typeof user !== "undefined") { %>
                    <span class="mr-2 d-none d-lg-inline text-gray-600 small">
                    <%= user.name %> <%= user.lastname %>
                    </span>
                <% } else { %>
                    <span class="mr-2 d-none d-lg-inline text-gray-600 small">
                    Guest
                    </span>
                <% } %>
                <!-- <img class="img-profile rounded-circle"
                    src="img/EverythingBecomesADragonTheCloserItApproachesTheOmnipotent.jpg"> -->
                <img class="img-profile rounded-circle" style="border: 1px solid #ccc;"
                    src="<%= user.picture ? `/image/${user.picture}` : '/img/undraw_profile.svg' %>">
            </a>
            <!-- Dropdown - User Information -->
            <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in"
                aria-labelledby="userDropdown">
                <% if (typeof user !== "undefined") { %>
                <a class="dropdown-item" href="/profile">
                    <i class="fas fa-user fa-sm fa-fw mr-2 text-gray-400"></i>
                    Profile
                </a>
                <!--<a class="dropdown-item" href="#">
                    <i class="fas fa-cogs fa-sm fa-fw mr-2 text-gray-400"></i>
                    Settings
                </a>
                <a class="dropdown-item" href="#">
                    <i class="fas fa-list fa-sm fa-fw mr-2 text-gray-400"></i>
                    Activity Log
                </a>-->
                <div class="dropdown-divider"></div>
                <a class="dropdown-item" href="#" data-toggle="modal" data-target="#logoutModal">
                    <i class="fas fa-sign-out-alt fa-sm fa-fw mr-2 text-gray-400"></i>
                    Logout
                </a>
                <% } else { %>
                    <a class="dropdown-item" href="/login">
                    <i class="fas fa-sign-out-alt fa-sm fa-fw mr-2 text-gray-400"></i>
                        Login
                    </a>
                <% } %>
            </div>
        </li>

    </ul>
</nav>
<script src="/socket.io/socket.io.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const bridge = document.getElementById('socket-bridge');
        if (!bridge) return;

        const currentUsername = bridge.getAttribute('data-username');
        const socket = io({ query: { username: currentUsername } });
        
        const alertBadge = document.getElementById('alert-badge');
        const alertContainer = document.getElementById('alert-container');
        const notiBadge = document.getElementById('noti-badge');
        const notiContainer = document.getElementById('noti-container');
        
        const loadMoreBtn = document.getElementById('load-more-btn'); // ปุ่มของ Message
        const loadMoreAlertsBtn = document.getElementById('load-more-alerts-btn'); // ปุ่มของ Alert

        // ✅ แยกตัวแปรเก็บหน้าของแต่ละฝั่ง
        let msgPage = 1;
        let alertPage = 1;
        const limit = 5;

        // 1. ฟังก์ชันสร้าง HTML สำหรับ Message (ซองจดหมาย)
        function getNotiItemHTML(data) {
            const content = data.text || data.messageText;
            const sender = data.senderName || "ระบบ";
            const isRead = data.isRead;
            const profileImg = (data.senderPic && data.senderPic.filename) ? `/image/${data.senderPic.filename}` : '/img/undraw_profile.svg';
            const unreadClass = isRead ? "" : "font-weight-bold bg-light";
            const gId = (data.group && data.group._id) ? data.group._id : (data.group || data.groupId);
            
            return `
                <a class="dropdown-item d-flex align-items-center ${unreadClass}" 
                   href="/group?open=${gId}" onclick="handleNotiClick(event, '${data._id}', ${isRead})">
                    <div class="dropdown-list-image mr-3">
                        <img class="rounded-circle" src="${profileImg}" style="width:40px; height:40px; object-fit:cover;">
                        ${!isRead ? '<div class="status-indicator bg-primary"></div>' : ''}
                    </div>
                    <div>
                        <div class="text-truncate">${content}</div>
                        <div class="small text-gray-500">${sender}</div>
                    </div>
                </a>`;
        }

        // 2. ฟังก์ชันสร้าง HTML สำหรับ Alert (ระฆัง)
        function getAlertItemHTML(data) {
            const isRead = data.isRead;
            const unreadClass = isRead ? "" : "font-weight-bold bg-light";
            return `
                <a class="dropdown-item d-flex align-items-center ${unreadClass}" 
                   href="/event" onclick="handleNotiClick(event, '${data._id}', ${isRead})">
                    <div class="mr-3">
                        <div class="icon-circle bg-primary"><i class="fas fa-file-alt text-white"></i></div>
                    </div>
                    <div>
                        <div class="small text-gray-500">${new Date(data.createdAt).toLocaleDateString('th-TH')}</div>
                        <span class="text-truncate d-block" style="max-width: 200px;">${data.text}</span>
                    </div>
                </a>`;
        }

        // 3. ฟังก์ชันดึงข้อมูลจาก Server
        function fetchNotifications(page, type, append = false) {
            fetch(`/api/notifications/unread?page=${page}&limit=${limit}&targetType=${type}`)
                .then(res => res.json())
                .then(notifications => {
                    // กรองข้อมูลตามประเภทที่ต้องการ
                    const alerts = notifications.filter(n => n.recipient.includes('ALL') || n.type === 'new_alert');
                    const messages = notifications.filter(n => !n.recipient.includes('ALL') && n.type === 'new_message');

                    // --- กรณีโหลดฝั่ง Alerts ---
                    if (type === 'alert') {
                        if (page === 1 && !append) alertContainer.innerHTML = '';
                        if (alerts.length > 0) {
                            alerts.forEach(a => {
                                if (!document.querySelector(`[onclick*="${a._id}"]`)) {
                                    alertContainer.insertAdjacentHTML('beforeend', getAlertItemHTML(a));
                                }
                            });
                        } else if (!append) {
                            alertContainer.innerHTML = '<div class="dropdown-item text-center small text-gray-500">ไม่มีประกาศ</div>';
                        }
                        // ซ่อนปุ่มถ้าหมดแล้ว
                        loadMoreAlertsBtn.style.display = alerts.length < limit ? 'none' : 'block';
                        loadMoreAlertsBtn.innerText = "Read More Alerts";
                    }

                    // --- กรณีโหลดฝั่ง Messages ---
                    if (type === 'message') {
                        if (page === 1 && !append) notiContainer.innerHTML = '';
                        if (messages.length > 0) {
                            messages.forEach(m => {
                                if (!document.querySelector(`[onclick*="${m._id}"]`)) {
                                    notiContainer.insertAdjacentHTML('beforeend', getNotiItemHTML(m));
                                }
                            });
                        } else if (!append) {
                            notiContainer.innerHTML = '<div class="dropdown-item text-center small text-gray-500">ไม่มีข้อความ</div>';
                        }
                        // ซ่อนปุ่มถ้าหมดแล้ว
                        loadMoreBtn.style.display = messages.length < limit ? 'none' : 'block';
                        loadMoreBtn.innerText = "Read More Messages";
                    }

                    // อัปเดต Badge เฉพาะตอนโหลดครั้งแรก
                    if (page === 1) updateBadgeUI();
                });
        }
        
        async function updateBadgeUI() {
            const res = await fetch('/api/notifications/count');
            const data = await res.json();
            
            // จัดการ Alert Badge (ระฆัง)
            if (data.alertUnread > 0) {
                alertBadge.textContent = data.alertUnread;
                alertBadge.style.display = 'block';
            } else {
                alertBadge.style.display = 'none';
            }

            // จัดการ Message Badge (ซองจดหมาย)
            if (data.messageUnread > 0) {
                notiBadge.textContent = data.messageUnread;
                notiBadge.style.display = 'block';
            } else {
                notiBadge.style.display = 'none';
            }
        }

        // --- Event Listeners ---
        loadMoreBtn.addEventListener('click', () => {
            msgPage++;
            loadMoreBtn.innerText = "Loading...";
            fetchNotifications(msgPage, 'message', true);
        });

        loadMoreAlertsBtn.addEventListener('click', () => {
            alertPage++;
            loadMoreAlertsBtn.innerText = "Loading...";
            fetchNotifications(alertPage, 'alert', true);
        });

        // โหลดข้อมูลครั้งแรก
        fetchNotifications(1, 'message');
        fetchNotifications(1, 'alert');

        // 4. รับข้อมูลสดๆ จาก Socket
        socket.on("new_notification", function(data) {
            data.isRead = false;
            // ปรับเงื่อนไขให้ตรงกับ Backend: group_alert หรือ new_alert
            if (data.recipient.includes('ALL') || data.type === 'new_alert' || data.type === 'group_alert') {
                alertBadge.style.display = 'block';
                alertBadge.textContent = (parseInt(alertBadge.textContent) || 0) + 1;
                if (alertContainer.innerHTML.includes("ไม่มีประกาศ")) alertContainer.innerHTML = '';
                alertContainer.insertAdjacentHTML('afterbegin', getAlertItemHTML(data));
            } else if (data.type === 'new_message') {
                notiBadge.style.display = 'block';
                notiBadge.textContent = (parseInt(notiBadge.textContent) || 0) + 1;
                if (notiContainer.innerHTML.includes("ไม่มีข้อความ")) notiContainer.innerHTML = '';
                notiContainer.insertAdjacentHTML('afterbegin', getNotiItemHTML(data));
            }
        });
    });

    // ฟังก์ชันจัดการการคลิกอ่าน
    async function handleNotiClick(event, notiId, isRead) {
        event.preventDefault();
        const targetUrl = event.currentTarget.getAttribute('href');
        if (!isRead) {
            try {
                await fetch(`/api/notifications/mark-read/${notiId}`, { method: 'POST' });
            } catch (err) { console.error("Mark read error:", err); }
        }
        window.location.href = targetUrl;
    }
</script>
<!-- End of Topbar -->