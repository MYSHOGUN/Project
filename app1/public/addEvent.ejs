<style>
    /* ✅ 1. Layout & Wrapper */
    .add-event-wrapper {
        min-height: 85vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 0;
        background-color: #f8f9fc;
    }

    .glass-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        padding: 3rem;
        width: 100%;
        max-width: 700px;
        border: 1px solid rgba(255, 255, 255, 0.8);
    }

    /* ✅ 2. Typography & Header */
    .header-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: #4e73df;
        margin-bottom: 2rem;
        text-align: center;
    }

    .input-label {
        font-weight: 600;
        color: #5a5c69;
        margin-bottom: 0.5rem;
        display: block;
        font-size: 0.9rem;
    }

    /* ✅ 3. Custom Inputs & Selects */
    .custom-select-modern {
        height: 50px !important;
        border-radius: 12px !important;
        border: 2px solid #eaecf4 !important;
        padding: 0 15px !important;
        transition: all 0.3s ease;
        font-weight: 500;
    }

    .custom-select-modern:focus {
        border-color: #4e73df !important;
        box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.1) !important;
    }

    .dropdownSelector {
        background: #4e73df;
        color: white;
        border: none;
        border-radius: 12px;
        height: 55px;
        font-weight: 600;
        letter-spacing: 0.5px;
        width: 100%;
        transition: all 0.3s ease;
    }

    .dropdownSelector:hover {
        background: #2e59d9;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(78, 115, 223, 0.3);
    }

    /* ✅ 4. File Upload (Premium look) */
    #drop-area {
        width: 100%;
        height: 180px;
        border: 2px dashed #d1d3e2;
        border-radius: 15px;
        background: #fdfdfd;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        transition: all 0.3s ease;
        color: #b7b9cc;
    }

    #drop-area:hover, #drop-area.hover {
        background: #f0f3ff;
        border-color: #4e73df;
        color: #4e73df;
    }

    #drop-area i { font-size: 2.5rem; margin-bottom: 10px; }

    /* ✅ 5. Buttons */
    .btn-save {
        background: #1cc88a;
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 700;
        color: white;
        transition: all 0.3s ease;
    }

    .btn-save:hover {
        background: #17a673;
        transform: scale(1.05);
    }

    .btn-cancel {
        background-color: #e74a3b;
        border: 2px solid #e74a3b;
        color: white;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 700;
        margin-left: 10px;
        transition: all 0.3s ease;
    }

    .btn-cancel:hover { background: #c82333; transform: scale(1.05); }

    .btn-view {
        background: #4e73df;
        border: none;
        border-radius: 12px;
        padding: 10px 10px;
        font-weight: 600;
        color: white;
        transition: all 0.3s ease;
    }

    .btn-view:hover {
        background: #2e59d9;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(78, 115, 223, 0.3);
    }

    .large-rectangle-image {
        /* ✅ แสดงผลตามสัดส่วนเดิม 100% ไม่บีบ ไม่ Crop */
        object-fit: contain !important; 
        
        /* ✅ บังคับความสูงสูงสุดไม่ให้ล้นจอ (90% ของความสูงจอ) */
        max-height: 90vh !important; 
        
        /* ✅ เพิ่ม Shadow หนาๆ ให้รูปดูลอยเด่นออกมา */
        box-shadow: 0 20px 50px rgba(0,0,0,0.8) !important;
        border-radius: 4px; 
        margin: 40px !important;
    }

    /* ลบ Padding และขอบขาวของ SweetAlert ให้เหลือน้อยที่สุด */
    .swal2-popup {
        padding: 0 !important; /* ลด padding เพื่อให้ปุ่มอ้างอิงขอบรูปได้แม่นยำ */
        background: none !important; 
        width: auto !important;
        overflow: visible !important; /* สำคัญ: เพื่อให้ปุ่มที่ลอยออกไปไม่โดนตัดทิ้ง */
    }

    .swal2-close {
        position: absolute !important;
        /* ✅ ใช้ค่าติดลบเพื่อดึงปุ่มออกไปนอกขอบรูป */
        top: -50px !important; 
        right: -100px !important;
        
        /* ตกแต่งปุ่มให้เห็นชัดบนพื้นหลังมืด */
        color: white !important;
        font-size: 50px !important; /* ขนาดกากบาท */
        background: none !important; 
        border: none !important;
        outline: none !important;
        transition: transform 0.2s;
    }

    .swal2-close:hover {
        transform: scale(1.2); /* ขยายใหญ่ขึ้นเวลาเอาเมาส์ชี้ */
        color: #ff4d4d !important; /* เปลี่ยนเป็นสีแดงอ่อนๆ */
    }
</style>

<div class="container-fluid add-event-wrapper">
    <div class="glass-card">
        <h1 class="header-title">
            <i class="fas fa-calendar-plus mr-2"></i> จัดตารางกิจกรรม
        </h1>

        <div class="form-group">
            <label class="input-label">ประเภทกิจกรรม</label>
            <div class="dropdown">
                <button class="btn dropdown-toggle dropdownSelector" type="button" id="dropdownMenuButton" data-toggle="dropdown">
                    เลือกกิจกรรม
                </button>
                <div class="dropdown-menu shadow animated--fade-in" style="width: 100%; border-radius: 12px;">
                    <a class="dropdown-item py-3" href="#" onclick="selectActivity(this)">วันส่งเอกสาร</a>
                    <a class="dropdown-item py-3" href="#" onclick="selectActivity(this)">วันสอบ</a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item py-3" href="#" onclick="selectActivity(this)">อื่นๆ</a>
                </div>
            </div>
        </div>

        <div class="form-group mt-4">
            <label class="input-label">เริ่มวันที่</label>
            <div class="row no-gutters" style="gap: 10px;">
                <div class="col">
                    <select id="selectYear" class="form-control custom-select-modern" onchange="populateDays('selectDay', 'selectMonth', 'selectYear'); updateToDateOptions(); updateSelectedDate();">
                        <option value="" disabled selected hidden>ปี (พ.ศ.)</option>
                    </select>
                </div>
                <div class="col">
                    <select id="selectMonth" class="form-control custom-select-modern" onchange="populateDays('selectDay', 'selectMonth', 'selectYear'); updateToDateOptions(); updateSelectedDate();" disabled>
                        <option value="" disabled selected hidden>เดือน</option>
                    </select>
                </div>
                <div class="col">
                    <select id="selectDay" class="form-control custom-select-modern" onchange="updateToDateOptions(); updateSelectedDate();" disabled>
                        <option value="" disabled selected hidden>วัน</option>
                    </select>
                </div>
            </div>
        </div>

        <div id="toDate" style="display: none;" class="animated--grow-in">
            <div class="text-center my-3"><span class="badge badge-light text-gray-500">ถึง</span></div>
            <div class="row no-gutters" style="gap: 10px;">
                <div class="col">
                    <select id="selectYear2" class="form-control custom-select-modern" onchange="updateToDateOptions(); updateSelectedDate();">
                        <option value="" disabled selected hidden>ปี (พ.ศ.)</option>
                    </select>
                </div>
                <div class="col">
                    <select id="selectMonth2" class="form-control custom-select-modern" onchange="updateToDateOptions(); updateSelectedDate();" disabled>
                        <option value="" disabled selected hidden>เดือน</option>
                    </select>
                </div>
                <div class="col">
                    <select id="selectDay2" class="form-control custom-select-modern" onchange="updateSelectedDate()" disabled>
                        <option value="" disabled selected hidden>วัน</option>
                    </select>
                </div>
            </div>
        </div>

        <div id="extraInfo">
            <input id="eventName" type="text" class="form-control custom-select-modern mt-4" placeholder="ชื่อกิจกรรม" style="display:none; height: 50px !important;">
            <textarea class="form-control mt-3" id="eventDescription" rows="4" placeholder="ระบุรายละเอียดกิจกรรมที่นี่..." style="display:none; border-radius: 12px; border: 2px solid #eaecf4;"></textarea>
        </div>

        <div id="fileUploadSection" class="mt-4 d-none flex-column">
            <div class="justify-content-between d-flex align-items-center mb-3">
                <label class="input-label">ตารางสอบ (Excel)</label>
                <button id="viewImageBtn" class="btn btn-view shadow-sm">
                    <i class="fas fa-image"></i> ดูรูปภาพตัวอย่าง Excel เพิ่มข้อมูลตารางสอบ
                </button>
            </div>
            <div id="drop-area">
                <i class="fas fa-file-excel"></i>
                <p id="defaultDropText" class="mb-0 px-4">ลากไฟล์ Excel มาวาง หรือ คลิกเพื่อเลือกไฟล์</p>
                <input type="file" id="file-input" style="display:none;" accept=".xlsx, .xls">
            </div>
        </div>

        <div class="d-flex justify-content-center mt-5">
            <button class="btn btn-save shadow-sm" id="saveEventBtn">
                <i class="fas fa-save mr-2"></i> บันทึกกิจกรรม
            </button>
            <button class="btn btn-cancel shadow-sm" id="cancelEventBtn" onclick="resetForm()">
                ยกเลิก
            </button>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let toDate = document.getElementById("toDate");
    let selectedValue = "";
    
    const fileUploadSection = document.getElementById("fileUploadSection");
    let selectedFile = null;
    const dropArea = document.getElementById('drop-area');
    const defaultDropText = document.getElementById('defaultDropText'); // ข้อความเริ่มต้น
    const fileInput = document.getElementById('file-input');
    const allowedTypes = [
        'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet', // .xlsx
        'application/vnd.ms-excel', // .xls
        'application/vnd.ms-office' 
    ];
    const defaultDropAreaBorder = '2px dashed #ccc'; 

    const saveEventBtn = document.getElementById("saveEventBtn");
    const cancelEventBtn = document.getElementById("cancelEventBtn");

    const eventName = document.getElementById("eventName");
    const eventDescription = document.getElementById("eventDescription");

    const monthTh = ["มกราคม", "กุมภาพันธ์", "มีนาคม", "เมษายน", "พฤษภาคม", "มิถุนายน", "กรกฎาคม", "สิงหาคม", "กันยายน", "ตุลาคม", "พฤศจิกายน", "ธันวาคม"];

    function initDatePicker() {
        const pickerSets = [
            { year: "selectYear", month: "selectMonth", day: "selectDay" },
            { year: "selectYear2", month: "selectMonth2", day: "selectDay2" }
        ];

        const now = new Date();
        const currentYear = now.getFullYear();
        const currentMonth = now.getMonth() + 1; // 1-12

        pickerSets.forEach(set => {
            const sMonth = document.getElementById(set.month);
            const sYear = document.getElementById(set.year);
            if (!sMonth || !sYear) return;

            sMonth.innerHTML = '<option value="" disabled selected hidden>เดือน</option>';
            sYear.innerHTML = '<option value="" disabled selected hidden>ปี (พ.ศ.)</option>';

            // ปี: วนจากปัจจุบันไปอีก 10 ปี
            for (let i = currentYear; i <= currentYear + 10; i++) {
                sYear.add(new Option(i + 543, i));
            }

            // เดือน: จะถูกเติมเมื่อมีการเลือกปีใน onchange หรือเรียกผ่านฟังก์ชันนี้
            updateMonthOptions(set.month, set.year);
            populateDays(set.day, set.month, set.year);
        });
    }

    // ฟังก์ชันใหม่: ช่วยกรองเดือนตามปีที่เลือก (ป้องกันเดือนในอดีต)
    function updateMonthOptions(monthId, yearId) {
        const sMonth = document.getElementById(monthId);
        const sYearValue = parseInt(document.getElementById(yearId).value);
        const now = new Date();
        const currentYear = now.getFullYear();
        const currentMonth = now.getMonth() + 1;

        const currentSel = sMonth.value;
        sMonth.innerHTML = '<option value="" disabled selected hidden>เดือน</option>';

        monthTh.forEach((m, index) => {
            const monthNum = index + 1;
            // ถ้าเลือกปีปัจจุบัน ห้ามเลือกเดือนที่ผ่านมาแล้ว
            if (sYearValue === currentYear && monthNum < currentMonth) return;
            sMonth.add(new Option(m, monthNum));
        });
        sMonth.value = currentSel;
    }

    function populateDays(dayId, monthId, yearId) {
        const sDay = document.getElementById(dayId);
        const sMonthValue = parseInt(document.getElementById(monthId).value);
        const sYearValue = parseInt(document.getElementById(yearId).value);
        
        const now = new Date();
        const currentYear = now.getFullYear();
        const currentMonth = now.getMonth() + 1;
        const currentDate = now.getDate();

        const startDay = parseInt(document.getElementById("selectDay").value) || 0;
        const startMonth = parseInt(document.getElementById("selectMonth").value) || 0;
        const startYear = parseInt(document.getElementById("selectYear").value) || 0;

        sDay.innerHTML = '<option value="" disabled selected hidden>วัน</option>';

        if (sMonthValue && sYearValue) {
            sDay.disabled = false;
            const daysInMonth = new Date(sYearValue, sMonthValue, 0).getDate();
            
            for (let d = 1; d <= daysInMonth; d++) {
                // 1. ป้องกันวันในอดีต (สำหรับชุดที่ 1)
                if (dayId === 'selectDay') {
                    if (sYearValue === currentYear && sMonthValue === currentMonth && d < currentDate) continue;
                }

                // 2. ป้องกันวันสิ้นสุดก่อนวันเริ่มต้น (สำหรับชุดที่ 2)
                if (dayId === 'selectDay2') {
                    if (sYearValue === startYear && sMonthValue === startMonth && d < startDay) continue;
                }

                sDay.add(new Option(d, d));
            }
        } else {
            sDay.disabled = true;
        }
    }

    function updateMonthOptions(monthId, yearId) {
        const sMonth = document.getElementById(monthId);
        const sYear = document.getElementById(yearId);
        const sYearValue = parseInt(sYear.value);
        
        // --- ส่วนที่เพิ่มเพื่อ Lock/Unlock เดือน ---
        if (sYearValue) {
            sMonth.disabled = false; // ปลดล็อคเมื่อเลือกปีแล้ว
        } else {
            sMonth.disabled = true;  // ล็อคไว้ถ้ายังไม่เลือกปี
            sMonth.value = "";
            return; 
        }
        // ---------------------------------------

        const now = new Date();
        const currentYear = now.getFullYear();
        const currentMonth = now.getMonth() + 1;
        const currentSel = sMonth.value;
        
        sMonth.innerHTML = '<option value="" disabled selected hidden>เดือน</option>';

        monthTh.forEach((name, index) => {
            const monthNum = index + 1;
            // Logic กรองเดือนในอดีต
            if (monthId === 'selectMonth') {
                if (sYearValue === currentYear && monthNum < currentMonth) return;
            }
            if (monthId === 'selectMonth2') {
                const startYear = parseInt(document.getElementById("selectYear").value) || 0;
                const startMonth = parseInt(document.getElementById("selectMonth").value) || 0;
                if (sYearValue === startYear && monthNum < startMonth) return;
            }
            sMonth.add(new Option(name, monthNum));
        });
        sMonth.value = currentSel;
    }

    function updateToDateOptions() {
        // อัปเดต List เดือนของทั้งสองชุดก่อน (เผื่อมีการสลับปีไปมา)
        updateMonthOptions('selectMonth', 'selectYear');
        updateMonthOptions('selectMonth2', 'selectYear2');

        const sYear = document.getElementById("selectYear");
        const sYear2 = document.getElementById("selectYear2");
        const startYear = parseInt(sYear.value) || 0;

        // กรองปีชุดที่ 2 ไม่ให้ต่ำกว่าชุดที่ 1
        const currentYear = new Date().getFullYear();
        const savedYear2 = sYear2.value;
        sYear2.innerHTML = '<option value="" disabled selected hidden>ปี (พ.ศ.)</option>';
        for (let i = currentYear; i <= currentYear + 10; i++) {
            if (i < startYear) continue;
            sYear2.add(new Option(i + 543, i));
        }
        sYear2.value = savedYear2;

        // รีเฟรชวันของชุดที่ 2
        populateDays('selectDay2', 'selectMonth2', 'selectYear2');
    }

    function selectActivity(element) {
        selectedValue = element.innerText;
        document.getElementById("dropdownMenuButton").innerText = selectedValue;

        if(selectedValue === "วันสอบ") {
            toDate.style.display = "block";
            eventDescription.style.display = "none";
            eventName.style.display = "none";
            fileUploadSection.classList.remove("d-none");
            fileUploadSection.classList.add("d-flex");
        } else {
            fileUploadSection.classList.remove("d-flex");
            fileUploadSection.classList.add("d-none");
            toDate.style.display = "none";
            document.getElementById("selectDay2").value = "";
            document.getElementById("selectMonth2").value = "";
            document.getElementById("selectYear2").value = "";
            
            if (selectedValue === "อื่นๆ") {
                eventName.style.display = "block";
                eventDescription.style.display = "block";
            } else {
                eventName.style.display = "none";
                eventDescription.style.display = "none";
            }
        }
        updateSelectedDate();
    }

    function updateSelectedDate() {
        const d = document.getElementById("selectDay").value;
        const m = document.getElementById("selectMonth").value;
        const y = document.getElementById("selectYear").value;

        if (d && m && y) {
            // ส่วนนี้ไว้เชื่อมกับ Calendar หรือ Preview ของคุณ
            console.log("Selected Start Date:", `${y}-${m}-${d}`);
        }
    }

    function resetForm() {
        document.getElementById("dropdownMenuButton").innerText = "เลือกกิจกรรม";
        selectedValue = "";
        toDate.style.display = "none";
        eventDescription.style.display = "none";
        eventDescription.value = "";
        eventName.style.display = "none";
        eventName.value = "";
        initDatePicker(); 
        saveEventBtn.disabled = false;
        saveEventBtn.innerText = "บันทึกกิจกรรม";
        window.location.href = "/event"
    }

    dropArea.addEventListener('dragover', (event) => {
        event.preventDefault();
        dropArea.style.border = '2px dashed green'; 
    });

    dropArea.addEventListener('dragleave', () => {
        // คืนค่า border เมื่อลากไฟล์ออก
        if (!selectedFile) {
            dropArea.style.border = defaultDropAreaBorder; 
        }
    });

    dropArea.addEventListener('drop', (event) => {
        event.preventDefault();
        const files = event.dataTransfer.files;
        handleFiles(files);
    });

    dropArea.addEventListener('click', () => {
        fileInput.click();
    });

    fileInput.addEventListener('change', () => {
        const files = fileInput.files;
        handleFiles(files);
    });

    // -------------------------------------------------------------
    // 2. ฟังก์ชันหลัก: จัดการไฟล์และตรวจสอบประเภท (แก้ไขให้แสดงชื่อไฟล์)
    // -------------------------------------------------------------
    function handleFiles(files) {
        const file = files[0];
        
        // 🚨 รีเซ็ตสถานะทั้งหมดให้กลับไปที่ค่าเริ่มต้นก่อน
        selectedFile = null;
        
        // รีเซ็ตการแสดงผล
        defaultDropText.innerHTML = 'ลากไฟล์ Excel มาวางที่นี่ หรือ คลิกเพื่อเลือกไฟล์';
        dropArea.style.border = defaultDropAreaBorder; 
        dropArea.style.backgroundColor = 'transparent'; 

        if (file) {
            // ตรวจสอบประเภทไฟล์
            const isAllowedType = allowedTypes.includes(file.type) || file.name.endsWith('.xlsx') || file.name.endsWith('.xls');

            if (isAllowedType) {
                // ถ้าเป็นไฟล์ Excel ที่ยอมรับ
                selectedFile = file; 
                
                // 💡 ส่วนที่แก้ไข: แสดงชื่อไฟล์ใน Drop Area
                defaultDropText.innerHTML = `
                    ✅ **เลือกไฟล์สำเร็จ:**<br>
                    <span style="font-weight: bold; color: #155724;">${file.name}</span>
                `;
                dropArea.style.border = '2px solid green';
                dropArea.style.backgroundColor = '#e6ffe6';
                
            } else {
                // ถ้าไม่ใช่ไฟล์ Excel: แจ้งเตือน
                Swal.fire({
                    icon: 'error',
                    title: 'ไฟล์ไม่ถูกต้อง',
                    html: `ไฟล์ที่เลือกไม่ใช่ไฟล์ Excel ที่ถูกต้อง (ยอมรับ: .xlsx, .xls)<br>ประเภทที่เลือกคือ: <strong>${file.type || 'ไม่ทราบประเภท'}</strong>`,
                    confirmButtonText: 'ตกลง'
                });
                fileInput.value = ''; // ล้างค่าใน input
            }
        } else {
            fileInput.value = ''; 
        }
    }

    saveEventBtn.addEventListener("click", () => {
        const day = document.getElementById("selectDay").value;
        const month = document.getElementById("selectMonth").value;
        const year = document.getElementById("selectYear").value;

        if (!selectedValue || selectedValue === "เลือกกิจกรรม" || !day || !month || !year) {
            Swal.fire({
                icon: 'warning',
                title: 'ข้อมูลไม่ครบถ้วน',
                text: 'กรุณาเลือกกิจกรรมและวันที่ให้ครบถ้วนก่อนบันทึก',
                confirmButtonText: 'ตกลง'
            });
            return;
        }

        // ตั้งค่า Description อัตโนมัติ
        const Name = eventName.value.trim();
        let desc = eventDescription.value.trim();
        if (selectedValue === "วันสอบ") desc = "จะมีการจัดสอบในวันที่กำหนด โปรดเตรียมเอกสารในการสอบให้เรียบร้อย";
        else if (selectedValue === "วันส่งเอกสาร") desc = "โปรดส่งเอกสารภายในวันที่กำหนด";
        else if (selectedValue === "อื่นๆ" && !desc && !eventName.value.trim()) {
            Swal.fire({
                icon: 'warning',
                title: 'ข้อมูลไม่ครบถ้วน',
                text: 'กรุณากรอกชื่อและรายละเอียดกิจกรรมสำหรับกิจกรรมอื่นๆ',
                confirmButtonText: 'ตกลง'
            });
            return;
        }
        // 1. ใช้ FormData แทน JSON ปกติเพื่อส่งไฟล์
        const formData = new FormData();
        formData.append("title", Name || selectedValue);
        formData.append("description", desc);
        formData.append("date", `${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`);

        if (toDate.style.display === "block") {
            const td = document.getElementById("selectDay2").value;
            const tm = document.getElementById("selectMonth2").value;
            const ty = document.getElementById("selectYear2").value;
            if (td && tm && ty) {
                formData.append("toDate", `${ty}-${tm.padStart(2, '0')}-${td.padStart(2, '0')}`);
            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'ข้อมูลไม่ครบถ้วน',
                    text: 'กรุณาเลือกวันที่สิ้นสุดสำหรับกิจกรรมวันสอบ',
                    confirmButtonText: 'ตกลง'
                });
                return;
            }
            
            // ตรวจสอบไฟล์สำหรับกิจกรรมวันสอบ
            if (!selectedFile) {
                Swal.fire({
                    icon: 'warning',
                    title: 'ข้อมูลไม่ครบถ้วน',
                    text: 'กรุณาเลือกไฟล์ Excel สำหรับกิจกรรมวันสอบ',
                    confirmButtonText: 'ตกลง'
                });
                return;
            }
            formData.append("file", selectedFile);
        }

        saveEventBtn.disabled = true;
        saveEventBtn.innerText = "กำลังบันทึก...";

        // 2. ส่งข้อมูลไปยัง API
        fetch('/api/addEvent', {
            method: 'POST',
            // หมายเหตุ: ไม่ต้องตั้ง Content-Type เมื่อใช้ FormData เบราว์เซอร์จะจัดการให้เอง
            body: formData 
        })
        .then(async response => {
            const result = await response.json();
            if (response.ok) {
                if (result.missingGroups && result.missingGroups.length > 0) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'บันทึกสำเร็จ (แต่ข้อมูลไม่ครบ)',
                        html: `${result.warning}<br><br><b class="text-danger">${result.missingGroups.join(', ')}</b><br><br>กรุณาตรวจสอบชื่อกลุ่มใน Excel ให้ตรงกับในระบบ`,
                        confirmButtonText: 'รับทราบ'
                    }).then(() => window.location.href = "/event");
                } else {
                    Swal.fire({
                        icon: 'success',
                        title: 'บันทึกสำเร็จ',
                        confirmButtonText: 'ตกลง'
                    }).then(() => window.location.href = "/event");
                }
            } else {
                // 💡 แสดงผล Error ที่ส่งมาจาก Server ถ้าไม่มีให้ใช้ข้อความ Default
                const errorMsg = result.message || result.error || "เกิดข้อผิดพลาดที่ไม่ทราบสาเหตุ";
                Swal.fire({
                    icon: 'error',
                    title: 'บันทึกกิจกรรมไม่สำเร็จ',
                    text: errorMsg,
                    confirmButtonText: 'ตกลง'
                });

                // 💡 พิมพ์ลง Console ของ Browser ไว้เช็คละเอียดๆ
                console.error("Server Result:", result); 

                saveEventBtn.disabled = false;
                saveEventBtn.innerText = "บันทึกกิจกรรม";
            }
        })
    });

    document.getElementById('viewImageBtn').addEventListener('click', function() {
        Swal.fire({
            imageUrl: '/img/preview.png', // ใส่ URL รูปของคุณที่นี่
            imageAlt: 'รูปตัวอย่างตารางสอบ',
            width: '85%',
            imageWidth: '100%', // ปรับขนาดรูปให้เต็มความกว้างของ Pop-up
            showConfirmButton: false, // ปิดปุ่มตกลง (เพราะเน้นดูรูป)
            showCloseButton: true,    // แสดงปุ่มกากบาทมุมบนขวา
            background: 'transparent', // ทำให้พื้นหลัง Pop-up ใส
            backdrop: `rgba(0,0,0,0.8)`, // พื้นหลังสีดำจางๆ ด้านนอก
            customClass: {
                image: 'large-rectangle-image' // เพิ่ม Class CSS ให้รูปภาพ
            }
        });
    });

    document.addEventListener("DOMContentLoaded", initDatePicker);
</script>