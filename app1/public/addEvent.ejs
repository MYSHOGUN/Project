        // 🚩 ใช้ insertAdjacentHTML เพื่อ "ต่อท้าย" โดยไม่ล้างของเก่า
        return sectionHTML;
    }

    function sourceGroup(selectedElement, sectionCount, selectValue, selfNum) {
        const groups = data.groups; // ข้อมูลกลุ่มทั้งหมดจาก API

        // 1. หา Select กลุ่มทุกตัวในหน้าจอ (ทั้งชุดปัจจุบันและชุดอื่นๆ)
        const allGroupSelects = Array.from(document.querySelectorAll('select[id^="group"]'))
            .filter(el => /group\d+-s\d+/.test(el.id));

        // 2. รวบรวม ID กลุ่มที่ถูกเลือกไว้แล้ว "ทั้งหมด" ในขณะนี้
        const globalSelectedValues = allGroupSelects
            .map(s => s.value)
            .filter(v => v !== "");

        // 3. สั่งให้ทุกช่องอัปเดตรายการใหม่ (เพื่อให้กลุ่มที่ถูกเลือกหายไปจากทุกช่อง)
        allGroupSelects.forEach((currentSelect) => {
            const currentValue = currentSelect.value; // เก็บค่าที่ช่องนี้เลือกอยู่ปัจจุบัน

            // ล้างรายการเก่า และใส่ "เลือกกลุ่ม" กลับเข้าไป
            currentSelect.innerHTML = `<option value="" disabled ${!currentValue ? 'selected' : ''} hidden>เลือกกลุ่ม</option>`;
            
            // 🚩 วนลูปจากข้อมูลดิบ (groups) เพื่อสร้าง Option ใหม่
            groups.forEach(g => {
                // เงื่อนไขในการยอมให้ชื่อกลุ่มปรากฏในรายการ:
                // - กลุ่มนี้ยังไม่ถูกใครเลือกเลย (!globalSelectedValues.includes)
                // - หรือ เป็นกลุ่มที่ช่องนี้เลือกอยู่เดิม (g._id === currentValue)
                if (!globalSelectedValues.includes(g._id) || g._id === currentValue) {
                    const opt = new Option(g.projectName, g._id);
                    if (g._id === currentValue) opt.selected = true;
                    currentSelect.add(opt);
                }
            });

            // บังคับคืนค่าเดิม (กันพลาด)
            currentSelect.value = currentValue;
        });

        // เรียกจัดการรายชื่ออาจารย์เฉพาะแถวที่เกิด Event
        if (typeof sourceTeacher === "function") {
            sourceTeacher(selectedElement, sectionCount, selfNum);
        }
    }

    function sourceTeacher(selectedElement, sectionCount, selfNum) {
        const groups = data.groups;
        const teachers = data.teachers;

        // 🚩 แก้ไขจุดที่ 1: ตรวจสอบก่อนว่า Select กลุ่มตัวนี้มีอยู่จริงไหม
        const groupEl = document.getElementById(`group${sectionCount}-s${selfNum}`);
        if (!groupEl) return; // ถ้าไม่เจอให้หยุดทำงานทันที

        const selectedGroupId = groupEl.value;
        
        // 🚩 แก้ไขจุดที่ 2: ตรวจสอบ Array ของ Directors
        const d1 = document.getElementById(`director-one-${sectionCount}-s${selfNum}`);
        const d2 = document.getElementById(`director-two-${sectionCount}-s${selfNum}`);
        const d3 = document.getElementById(`director-three-${sectionCount}-s${selfNum}`);

        // ถ้าไม่มีกรรมการครบ (เช่น ยังไม่ได้วาด HTML ชุดนั้น) ให้หยุดทำงาน
        if (!d1 || !d2 || !d3) return;

        const directors = [d1, d2, d3];

        let groupLeadUsername = "";
        let groupLeadDisplay = "";

        if (selectedGroupId) {
            const chosenGroup = groups.find(g => g._id === selectedGroupId);
            // ตรวจสอบโครงสร้างข้อมูล advisor (บางครั้งอาจเป็น string หรือ array)
            if (chosenGroup && chosenGroup.advisor) {
                const advisorUsername = Array.isArray(chosenGroup.advisor) ? chosenGroup.advisor[0] : chosenGroup.advisor;
                const leadInfo = teachers.find(t => t.username === advisorUsername);
                
                if (leadInfo) {
                    groupLeadUsername = leadInfo.username;
                    groupLeadDisplay = `${leadInfo.title || ""} ${leadInfo.name}`;
                }
            }
        }

    directors.forEach((currentSelect, index) => {
        if (!currentSelect) return; // กัน Error กรณีหา Element ไม่เจอ

        if (index === 0 && groupLeadUsername !== "") {
            currentSelect.innerHTML = `<option value="${groupLeadUsername}" selected>${groupLeadDisplay}</option>`;
            return; // หยุดลูปรอบ index 0 ไว้แค่นี้
        }

        const currentValue = currentSelect.value;
        const otherValues = directors
            .filter((s, i) => s && i !== index) // กัน Error ถ้า s เป็น null
            .map(s => s.value)
            .filter(v => v !== "");

        let optionsHTML = "";
        if (index === 0) optionsHTML = `<option value="" disabled selected hidden>อาจารย์ที่ปรึกษา</option>`;
        else if (index === 1) optionsHTML = `<option value="" disabled selected hidden>เลือกกรรมการ</option>`;
        else optionsHTML = `<option value="" disabled selected hidden>เลือกประธานกรรมการ</option>`;
        
        teachers.forEach(t => {
            if (!otherValues.includes(t.username)) {
                optionsHTML += `<option value="${t.username}">${t.title || ""} ${t.name}</option>`;
            }
        });

        // 🚩 อัปเดต HTML เสมอ
        currentSelect.innerHTML = optionsHTML;
        if (index === 0) {
            currentSelect.value = groupLeadUsername;
            currentSelect.style.backgroundColor = "#e9ecef";
            currentSelect.style.pointerEvents = "none";
        }

        // คืนค่าเดิมถ้าเป็นไปได้
        if (currentValue && !otherValues.includes(currentValue)) {
            currentSelect.value = currentValue;
        } else {
            currentSelect.value = "";
        }
    });
}

    function groupNumber(groupNumber) {
        const groupCount = document.getElementById(groupNumber);
        groupCount.innerHTML = '<option value="" disabled selected hidden>จำนวนกลุ่ม</option>';
        for (let i = 1; i <= 20; i++) {
            groupCount.add(new Option(i.toString()));
        }
    }
    groupNumber("select-group-number");

    function populateTime(selectElement, timeSectionCount, selectValue, selfNum) {
        const selectedValue = parseInt(selectElement.value); 
        
        for (let i = 1; i <= selectValue; i++) {
            if (i <= selfNum) continue;

            const timeElement = document.getElementById("time" + timeSectionCount + "-s" + i);
            if (!timeElement) continue;

            const currentValue = parseInt(timeElement.value) || 0;
            timeElement.innerHTML = '<option value="" disabled selected hidden>เลือกเวลา</option>';

            // 🚩 1. ถ้าตัวก่อนหน้าเลือก 20:00 (1200) หรือมากกว่าไปแล้ว ให้จบงานทันที
            if (selectedValue >= 1140) {
                const opt = new Option("ไม่เหลือเวลาว่าง", "");
                opt.disabled = true;
                timeElement.add(opt);
                timeElement.value = ""; 
                continue; 
            }

            let hasValidTime = false; // ตัวแปรเช็คว่ามีเวลาให้เลือกไหม

            outerLoop: for (let hour of timeTh[0]) {
                for (let minute of timeTh[1]) {
                    const totalMinutes = (parseInt(hour) * 60) + parseInt(minute);

                    // 🚩 2. ต้อง "มากกว่า" เท่านั้น (ถ้า 19:30 จะไม่ขึ้นในแถวถัดไป)
                    if (totalMinutes <= selectedValue) continue;

                    if (totalMinutes <= 1200) {
                        timeElement.add(new Option(`${hour}:${minute}`, totalMinutes));
                        hasValidTime = true; // มีเวลาให้เลือกแล้วอย่างน้อย 1 อัน
                        
                        // ถ้าแวะมาถึง 20:00 แล้ว ให้หยุดสร้าง Option ทันที
                        if (totalMinutes === 1200) break outerLoop;
                    }
                }
            }

            // 🚩 3. ถ้าวนลูปจนจบแล้ว "ไม่มีเวลาที่สายกว่า" ให้เลือกเลย
            if (!hasValidTime) {
                const opt = new Option("ไม่เหลือเวลาว่าง", "");
                opt.disabled = true;
                timeElement.add(opt);
            }

            if (currentValue <= selectedValue) {
                timeElement.value = "";
            }
        }
    }
    
    function initDatePicker() {
        let pickerSets = [];
        if (!sectionCount || sectionCount === 0 ){
            pickerSets = [
                { year: "selectYear", month: "selectMonth", day: "selectDay"},
                { year:"start-select-year", month:"start-select-month", day:"start-select-day"}
            ];
        }else{
             pickerSets = [{ year: "start-select-year"+sectionCount, month: "start-select-month"+sectionCount, day: "start-select-day"+sectionCount}]; 
        }

        const now = new Date();
        const currentYear = document.getElementById("start-select-year").value ? parseInt(document.getElementById("start-select-year").value) : now.getFullYear();
        const currentMonth = now.getMonth() + 1; // 1-12

        pickerSets.forEach(set => {
            const sYear = document.getElementById(set.year);
            if (!sYear) return;

            sYear.innerHTML = '<option value="" disabled selected hidden>ปี (พ.ศ.)</option>';

            // ปี: วนจากปัจจุบันไปอีก 10 ปี
            for (let i = currentYear; i <= currentYear + 10; i++) {
                sYear.add(new Option(i + 543, i));
            }
        });
    }

    function populateDays(dayId, monthId, yearId) {
        const sYear = document.getElementById(yearId);
        const sMonth = document.getElementById(monthId);
        const sDay = document.getElementById(dayId);
        if (!sDay || !sMonth || !sYear) return;

        // [1] หาลำดับของตัวเองและค่าปัจจุบัน
        const match = dayId.match(/\d+/);
        const myNum = match ? parseInt(match[0]) : 0; 
        const sYearValue = parseInt(sYear.value) || 0;
        const sMonthValue = parseInt(sMonth.value) || 0;
        const sDayValue = parseInt(sDay.value) || 0;

        // ดึงค่าวันที่ปัจจุบันมาใช้เฉพาะชุดแรก หรือใช้กรองพื้นฐาน
        const now = new Date();
        const nowDate = now.getDate();
        const nowMonth = now.getMonth() + 1;
        const nowYear = now.getFullYear();

        if(sYearValue > 0 && sMonthValue > 0) sDay.disabled = false;

        // --- ส่วนที่ 1: เติมวันให้ตัวเอง (sDay) ---
        const currentDay = sDay.value;
        const daysInMainMonth = new Date(sYearValue, sMonthValue, 0).getDate();
        sDay.innerHTML = '<option value="" disabled selected hidden>วัน</option>';

        // หา ID ของ "ชุดก่อนหน้า"
        let prevSuffix = "";
        if (myNum > 0) {
            prevSuffix = (myNum === 1) ? "" : (myNum - 1);
        }
        const pYear = document.getElementById("start-select-year" + prevSuffix);
        const pMonth = document.getElementById("start-select-month" + prevSuffix);
        const pDay = document.getElementById("start-select-day" + prevSuffix);

        for (let d = 1; d <= daysInMainMonth; d++) {
            // 🚩 เงื่อนไข A: สำหรับทุกชุด (รวมชุดแรก) ห้ามเก่ากว่าวันปัจจุบัน
            if (sYearValue === nowYear && sMonthValue === nowMonth && d < nowDate) {
                continue;
            }

            // 🚩 เงื่อนไข B: สำหรับชุดที่ 2 เป็นต้นไป ห้ามเก่ากว่าชุดก่อนหน้า
            if (selectedValue === "วันสอบ" && pYear && pMonth && pDay) {
                const pyVal = parseInt(pYear.value) || 0;
                const pmVal = parseInt(pMonth.value) || 0;
                const pdVal = parseInt(pDay.value) || 0;

                if (sYearValue === pyVal && sMonthValue === pmVal && pdVal > 0 && d <= pdVal) continue;
                if (sYearValue < pyVal || (sYearValue === pyVal && sMonthValue < pmVal)) continue;
            }
            
            sDay.add(new Option(d, d));
        }
        sDay.value = currentDay;
        if (sDay.selectedIndex === -1) sDay.value = "";


        // --- ส่วนที่ 2: สั่งให้ "ชุดถัดไป" อัปเดตตามเรา ---
        if (selectedValue === "วันสอบ") {
            for (let i = myNum + 1; i <= sectionCount; i++) {
                const suffix = i === 0 ? "" : i;
                const ty = document.getElementById("start-select-year" + suffix);
                const tm = document.getElementById("start-select-month" + suffix);
                const td = document.getElementById("start-select-day" + suffix);

                if (!td || !tm || !ty || td === sDay) continue;

                const targetYearValue = parseInt(ty.value) || 0;
                const targetMonthValue = parseInt(tm.value) || 0;
                const currentSelectedDay = td.value;

                const daysInTargetMonth = new Date(targetYearValue, targetMonthValue, 0).getDate();
                td.innerHTML = '<option value="" disabled selected hidden>วัน</option>';

                for (let d = 1; d <= daysInTargetMonth; d++) {
                    // กรองวันปัจจุบัน (กันเหนียวให้ชุดลูกด้วย)
                    if (targetYearValue === nowYear && targetMonthValue === nowMonth && d < nowDate) continue;

                    // กรองตามวันของชุดแม่ (เรา)
                    if (targetYearValue === sYearValue && targetMonthValue === sMonthValue) {
                        if (sDayValue > 0 && d <= sDayValue) continue;
                    }

                    if (targetYearValue < sYearValue || (targetYearValue === sYearValue && targetMonthValue < sMonthValue)) {
                        continue;
                    }

                    td.add(new Option(d, d));
                }
                td.value = currentSelectedDay;
                if (td.selectedIndex === -1) td.value = "";
            }
        }
    }

    function updateMonthOptions(monthId, yearId) {
        const sYear = document.getElementById(yearId);
        const sMonth = document.getElementById(monthId);
        if (!sMonth || !sYear) return;

        // [1] หาลำดับของตัวเองและค่าปัจจุบัน
        const match = monthId.match(/\d+/);
        const myNum = match ? parseInt(match[0]) : 0; 
        const sYearValue = parseInt(sYear.value) || 0;
        const sMonthValue = parseInt(sMonth.value) || 0;

        // ดึงค่าวันที่ปัจจุบันมาใช้เฉพาะชุดแรก หรือใช้กรองพื้นฐาน
        const now = new Date();
        const nowMonth = now.getMonth() + 1;
        const nowYear = now.getFullYear();

        if(sYearValue > 0 ) sMonth.disabled = false;

        // --- ส่วนที่ 1: เติมเดือนให้ตัวเอง (sMonth) ---
        const currentMonth = sMonth.value;
        sMonth.innerHTML = '<option value="" disabled selected hidden>เดือน</option>';

        // หา ID ของ "ชุดก่อนหน้า"
        let prevSuffix = "";
        if (myNum > 0) {
            prevSuffix = (myNum === 1) ? "" : (myNum - 1);
        }
        const pYear = document.getElementById("start-select-year" + prevSuffix);
        const pMonth = document.getElementById("start-select-month" + prevSuffix);
        const pDay = document.getElementById("start-select-day" + prevSuffix);

        for (let m = 1; m <= 12; m++) {
            // 🚩 เงื่อนไข A: สำหรับทุกชุด (รวมชุดแรก) ห้ามเก่ากว่าเดือนปัจจุบัน
            if (sYearValue === nowYear && m < nowMonth) {
                continue;
            }

            // 🚩 เงื่อนไข B: สำหรับชุดที่ 2 เป็นต้นไป ห้ามเก่ากว่าชุดก่อนหน้า
            if (selectedValue === "วันสอบ" && pYear && pMonth) {
                const pyVal = parseInt(pYear.value) || 0;
                const pmVal = parseInt(pMonth.value) || 0;

                if (sYearValue === pyVal &&  pmVal > 0 && m <= pmVal) continue;
                if (sYearValue < pyVal ) continue;
            }
            
            sMonth.add(new Option(monthTh[m-1], m));
        }
        sMonth.value = currentMonth;
        if (sMonth.selectedIndex === -1) sMonth.value = "";


        // --- ส่วนที่ 2: สั่งให้ "ชุดถัดไป" อัปเดตตามเรา ---
        if (selectedValue === "วันสอบ") {
            for (let i = myNum + 1; i <= sectionCount; i++) {
                const suffix = i === 0 ? "" : i;
                const ty = document.getElementById("start-select-year" + suffix);
                const tm = document.getElementById("start-select-month" + suffix);
                const td = document.getElementById("start-select-day" + suffix);

                if (!tm || !ty || tm === sMonth) continue;

                const targetYearValue = parseInt(ty.value) || 0;
                const currentSelectedMonth = tm.value;

                tm.innerHTML = '<option value="" disabled selected hidden>เดือน</option>';

                for (let m = 1; m <= 12; m++) {
                    // กรองวันปัจจุบัน (กันเหนียวให้ชุดลูกด้วย)
                    if (targetYearValue === nowYear && m < nowMonth) continue;

                    // กรองตามวันของชุดแม่ (เรา)
                    if (targetYearValue === sYearValue ) {
                        if (sMonthValue > 0 && m <= sMonthValue) continue;
                    }

                    if (targetYearValue < sYearValue) {
                        continue;
                    }

                    tm.add(new Option(monthTh[m-1], m));
                }
                tm.value = currentSelectedMonth;
                if (tm.selectedIndex === -1) {
                    tm.value = "";
                    td.value = "";
                    td.disabled = true;
                }
            }
        }
    }

    function updateYearOptions(yearId) {
        const sYear = document.getElementById(yearId);
        if (!sYear) return;

        // หาลำดับตัวเอง (ถ้าไม่มีเลขคือชุดที่ 0)
        const match = yearId.match(/\d+/);
        const selfNum = match ? parseInt(match[0]) : 0;
        const sYearValue = parseInt(sYear.value) || 0;
        const currentYear = new Date().getFullYear();
        // เติมปีให้ตัวเองถ้าว่าง
        if (sYear.options.length <= 1) {
            sYear.innerHTML = '<option value="" disabled selected hidden>ปี (พ.ศ.)</option>';
            for (let j = currentYear; j <= currentYear + 10; j++) {
                sYear.add(new Option(j + 543, j));
            }
        }

        if (selectedValue === "วันสอบ") {
            // 🚩 แก้ไข: เริ่มลูปที่ตัวถัดไปเท่านั้น (i = selfNum + 1)
            for (let i = selfNum + 1; i <= sectionCount; i++) {
                const ty = document.getElementById("start-select-year" + i);
                const tm = document.getElementById("start-select-month" + i);
                const td = document.getElementById("start-select-day" + i);

                if (!ty) continue;

                const targetValue = ty.value;
                ty.innerHTML = '<option value="" disabled selected hidden>ปี (พ.ศ.)</option>';
                let startY = sYearValue || new Date().getFullYear();
                for (let j = startY; j <= startY + 10; j++) {
                    ty.add(new Option(j + 543, j));
                }

                // ถ้าปีเดิมของชุดหลังยังใช้ได้ (ไม่น้อยกว่าตัวแม่) ให้เก็บไว้
                if (targetValue && parseInt(targetValue) >= sYearValue) {
                    ty.value = targetValue;
                } else {
                    ty.value = ""; if(tm) tm.value = ""; if(td) td.value = "";
                    tm.disabled = true;
                    td.disabled = true;
                }
            }
        }
    }

    function updateToDateOptions(sDay, sMonth, sYear) {
        updateYearOptions(sYear);
        updateMonthOptions(sMonth, sYear);
        populateDays(sDay, sMonth, sYear);
    }

    function selectActivity(element) {
        selectedValue = element.innerText;
        document.getElementById("dropdownMenuButton").innerText = selectedValue;
        const groupOnly = document.getElementById("groupOnlyCheckbox").checked;
        const startDate = document.getElementById("start-date");
        const onlyGroup = document.getElementById("onlyGroupSent")
        const teacherSum = document.getElementById("teacher-summary")
        startDate.style.display = "none";
        buttons.style.display = "flex";

        if(selectedValue === "วันสอบ") {
            teacherSum.style.display = "block";
            onlyGroup.style.display = "none";
            startLabel.innerText = "เริ่มวันที่"
            groupSelectNumber.style.display = "block";
            eventDescription.style.display = "none";
            eventName.style.display = "none";
            startDate.style.display = "none";
            document.getElementById("groupOnlyCheckbox").checked = false;
        } else {
            teacherSum.style.display = "none";
            onlyGroup.style.display = "block";
            startLabel.innerText = "ถึงวันที่"
            startDate.style.display = "block";
            groupSelectNumber.style.display = "none";
            
            if (selectedValue === "อื่นๆ") {
                eventName.style.display = "block";
                eventDescription.style.display = "block";
            } else {
                eventName.style.display = "none";
                eventDescription.style.display = "none";
            }
        }
    }

    function updateWorkloadUI() {
        const list = document.getElementById("workload-list");
        if (!list) return;
        list.innerHTML = ""; 

        const counts = {};

        // นับจากช่องกรรมการทั้งหมด (รวมที่ปรึกษาที่ถูกล็อกค่าไว้)
        document.querySelectorAll('select[id^="director"]').forEach(sel => {
            if (sel.value) {
                counts[sel.value] = (counts[sel.value] || 0) + 1;
            }
        });

        // เรียงลำดับคนงานเยอะขึ้นก่อน
        const sortedUsernames = Object.keys(counts).sort((a, b) => counts[b] - counts[a]);

        if (sortedUsernames.length === 0) {
            list.innerHTML = '<div class="text-center text-muted py-2">ยังไม่มีการเลือกอาจารย์</div>';
            return;
        }

        sortedUsernames.forEach(username => {
            const teacher = data.teachers.find(t => t.username === username);
            if (teacher) {
                const total = counts[username];
                // ไล่สีตามระดับภาระงาน (Bootstrap classes)
                let colorClass = "text-success";
                if (total > 10) colorClass = "text-danger font-weight-bold";
                else if (total > 7) colorClass = "text-warning";
                else if (total > 4) colorClass = "text-info";

                list.innerHTML += `
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="text-truncate" style="max-width: 110px;">${teacher.name.split(' ')[0]}</span> 
                        <span class="${colorClass}">${total} กลุ่ม</span>
                    </div>`;
            }
        });
    }
    updateWorkloadUI()

    function resetForm() {
        document.getElementById("dropdownMenuButton").innerText = "เลือกกิจกรรม";
        selectedValue = "";
        eventDescription.style.display = "none";
        eventDescription.value = "";
        eventName.style.display = "none";
        eventName.value = "";
        initDatePicker(); 
        saveEventBtn.disabled = false;
        saveEventBtn.innerText = "บันทึกกิจกรรม";
        window.location.href = "/event"
    }


    saveEventBtn.addEventListener("click", () => {
        const day = document.getElementById("selectDay").value;
        const month = document.getElementById("selectMonth").value;
        const year = document.getElementById("selectYear").value;
        const groupOnly = document.getElementById("groupOnlyCheckbox").checked;

        if (groupOnly && !chosenGroup) {
            Swal.fire({
                icon: 'warning',
                title: 'ข้อมูลไม่ครบถ้วน',
                text: 'กรุณาเลือกกลุ่มสำหรับกิจกรรมเฉพาะกลุ่ม',
                confirmButtonText: 'ตกลง'
            });
            return;
        }

        if (!selectedValue || selectedValue === "เลือกกิจกรรม"  || (selectedValue !== "วันสอบ" && (!day || !month || !year))) {
            Swal.fire({
                icon: 'warning',
                title: 'ข้อมูลไม่ครบถ้วน',
                text: 'กรุณาเลือกกิจกรรมและวันที่ให้ครบถ้วนก่อนบันทึก',
                confirmButtonText: 'ตกลง'
            });
            return;
        }

        // ตั้งค่า Description อัตโนมัติ
        const Name = eventName.value.trim();
        let desc = eventDescription.value.trim();
        if (selectedValue === "วันสอบ") desc = "จะมีการจัดสอบในวันที่กำหนด โปรดเตรียมเอกสารในการสอบให้เรียบร้อย";
        else if (selectedValue === "วันส่งเอกสาร") desc = "โปรดส่งเอกสารภายในวันที่กำหนด";
        else if (selectedValue === "อื่นๆ" && !desc && !eventName.value.trim()) {
            Swal.fire({
                icon: 'warning',
                title: 'ข้อมูลไม่ครบถ้วน',
                text: 'กรุณากรอกชื่อและรายละเอียดกิจกรรมสำหรับกิจกรรมอื่นๆ',
                confirmButtonText: 'ตกลง'
            });
            return;
        }
        // 1. ใช้ FormData แทน JSON ปกติเพื่อส่งไฟล์
        const formData = new FormData();
        formData.append("title", Name || selectedValue);
        formData.append("description", desc);
        formData.append("date", `${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`);
        if(groupOnly) formData.append("chosenGroup", chosenGroup);

        if (selectedValue === "วันสอบ") {
            let examData = []; // ก้อนข้อมูลหลัก

            for (let i = 1; i <= sectionCount; i++) {
                const year = document.getElementById(`start-select-year${i === 1 ? '' : i-1}`).value;
                const month = document.getElementById(`start-select-month${i === 1 ? '' : i-1}`).value;
                const day = document.getElementById(`start-select-day${i === 1 ? '' : i-1}`).value;
                const dateString = `${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;

                // 2. ดึงจำนวนแถว (selectedValue) ของชุดนั้น (สมมติเก็บไว้ใน attribute หรือตัวแปร)
                // ในที่นี้ต้องระวังว่าแต่ละ Section อาจมีจำนวนแถวไม่เท่ากัน 
                // แนะนำให้ดึงจากค่าของ select-group-number ในชุดนั้นๆ
                const rowsCount = parseInt(document.getElementById(`select-group-number${i === 1 ? '' : i-1}`).value);

                let details = [];
                for (let j = 1; j <= rowsCount; j++) {
                    const groupId = document.getElementById(`group${i}-s${j}`).value;
                    const timeValue = document.getElementById(`time${i}-s${j}`).value;
                    const d1 = document.getElementById(`director-one-${i}-s${j}`).value;
                    const d2 = document.getElementById(`director-two-${i}-s${j}`).value;
                    const d3 = document.getElementById(`director-three-${i}-s${j}`).value;

                    if(!groupId || !timeValue || !d1 || !d2 || !d3){
                        Swal.fire({
                            icon: 'warning',
                            title: 'ข้อมูลไม่ครบถ้วน',
                            text: "กรุณากรอกข้อมูลทุกช่องให้ครบถ้วน",
                            confirmButtonText: 'ตกลง'
                        });
                        return;
                    }

                    if (groupId) { // ส่งเฉพาะแถวที่มีการเลือกกลุ่ม
                        details.push({
                            group: groupId,
                            time: timeValue,
                            directors: [d1, d2, d3]
                        });
                    }
                }

                examData.push({
                    date: dateString,
                    slots: details
                });
            }

            // เตรียมส่งก้อนใหญ่
            console.log(examData)
            formData.append("examSchedule", JSON.stringify(examData));
        }

        saveEventBtn.disabled = true;
        saveEventBtn.innerText = "กำลังบันทึก...";

        Swal.fire({
            title: 'กำลังบันทึกกิจกรรม...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        let link;
        // 2. ส่งข้อมูลไปยัง API
        if (groupOnly && selectedValue !== "วันสอบ") {
            link = '/api/addEventForGroup';
        }else{
            link = '/api/addEvent';
        }
        fetch(link, {
            method: 'POST',
            // หมายเหตุ: ไม่ต้องตั้ง Content-Type เมื่อใช้ FormData เบราว์เซอร์จะจัดการให้เอง
            body: formData 
        })
        .then(async response => {
            const result = await response.json();
            if (response.ok) {
                if (result.missingGroups && result.missingGroups.length > 0) {
                    Swal.close();
                    Swal.fire({
                        icon: 'warning',
                        title: 'บันทึกสำเร็จ (แต่ข้อมูลไม่ครบ)',
                        html: `${result.warning}<br><br><b class="text-danger">${result.missingGroups.join(', ')}</b><br><br>กลุ่มเหล่านี้ยังไม่พร้อมสอบหรือกรุณาตรวจสอบชื่อกลุ่มใน Excel ให้ตรงกับในระบบ`,
                        confirmButtonText: 'รับทราบ'
                    }).then(() => window.location.href = "/event");
                } else {
                    Swal.close();
                    Swal.fire({
                        icon: 'success',
                        title: 'บันทึกสำเร็จ',
                        confirmButtonText: 'ตกลง'
                    }).then(() => window.location.href = "/event");
                }
            } else {
                // 💡 แสดงผล Error ที่ส่งมาจาก Server ถ้าไม่มีให้ใช้ข้อความ Default
                const errorMsg = result.message || result.error || "เกิดข้อผิดพลาดที่ไม่ทราบสาเหตุ";
                Swal.close();
                Swal.fire({
                    icon: 'error',
                    title: 'บันทึกกิจกรรมไม่สำเร็จ',
                    text: errorMsg,
                    confirmButtonText: 'ตกลง'
                });

                // 💡 พิมพ์ลง Console ของ Browser ไว้เช็คละเอียดๆ
                console.error("Server Result:", result); 

                saveEventBtn.disabled = false;
                saveEventBtn.innerText = "บันทึกกิจกรรม";
            }
        })
    });

    $(document).ready(function() {
        // 1. ตรวจจับการพิมพ์
        $("#searchGroup").on("input", function() {
            const keyword = $(this).val().trim();
            const $results = $("#searchGroupResults");           

            if (keyword.length > 1) {
                $.get("/search-group?keyword=" + encodeURIComponent(keyword), function(data) {
                    $results.empty().show();
                    
                    if (data && data.length > 0) {
                        data.forEach(group => {
                            $results.append(`
                                <li class="list-group-item list-group-item-action group-li" 
                                    data-groupname="${group.projectName}" 
                                    data-groupid="${group._id}" 
                                    style="cursor:pointer; border-radius: 12px;">
                                    <strong>${group.projectName}</strong>
                                </li>`);
                        });
                    } else {
                        $results.append(`<li class="list-group-item text-muted">ไม่พบข้อมูล</li>`);
                    }
                }).fail(function(err) {
                    console.error("API Error:", err);
                });
            } else {
                $results.hide().empty();
            }
        });

        // 2. คลิกเลือกกลุ่ม
        $(document).on("click", ".group-li", function() {
            const groupName = $(this).data("groupname");
            const groupId = $(this).data("groupid");
            
            chosenGroup = groupId;
            $("#selectedGroup").text(groupName);
            
            // จัดการ UI
            $("#searchGroupResults").hide().empty();
            $("#searchGroup").val(""); // ล้างช่องค้นหา
            $("#searchGroupContainer").hide();
            $("#selectedGroupContainer").css("display", "flex").show();
        });

        // 3. ยกเลิกการเลือก
        $("#clearGroupSelection").on("click", function() {
            chosenGroup = null;
            $("#selectedGroup").text("");
            $("#selectedGroupContainer").hide();
            $("#searchGroupContainer").show();
            $("#searchGroup").focus(); // ให้ Cursor ไปรอที่ช่องพิมพ์
        });
    });

    function updatePosition(target) {
        const summaryCard = document.getElementById("teacher-summary");
        if (!summaryCard || summaryCard.style.display === "none") return;

        // ดึงค่า Scroll จากตัวที่ส่งมา
        const scrollTop = target.scrollTop;

        if (scrollTop > 60) {
            summaryCard.style.setProperty("top", "20px", "important");
        } else {
            summaryCard.style.setProperty("top", "90px", "important");
        }
    }

    // 🚩 ตรวจสอบว่าตัวไหนในหน้าเว็บที่เป็นคน Scroll
    document.addEventListener('scroll', function(e) {
        // e.target คือตัวที่กำลังโดนไถอยู่
        updatePosition(e.target);
    }, true);

</script>